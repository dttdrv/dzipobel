    "adm-zip": "^0.5.16",
    "eslint": "^9.35.0",
    "eslint-plugin-astro": "^0.34.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  }
}
