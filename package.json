{
  "name": "dzipobel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "generate:content": "node ./scripts/generate-content.mjs",
    "typecheck": "astro check",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test -c ./playwright.config.ts",
