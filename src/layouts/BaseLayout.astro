---
import { ClientRouter } from "astro:transitions";

import "../styles/global.css";

const { title, description, pathname = Astro.url.pathname } = Astro.props;

const navItems = [
  { href: "/", label: "Начало" },
  { href: "/literatura/", label: "Литература" },
  { href: "/bulgarski/", label: "Български език" },
];
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="color-scheme" content="light dark" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ede7db" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111111" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Literata:opsz,wght@7..72,400;7..72,500;7..72,700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="site-aura site-aura--left" aria-hidden="true"></div>
    <div class="site-aura site-aura--right" aria-hidden="true"></div>

    <div class="site-shell">
      <header class="topbar">
        <a href="/" class="brand" aria-label="ДЗИ библиотека">
          <span class="brand-mark">12</span>
          <span class="brand-copy">
            <strong>ДЗИ библиотека</strong>
            <small>свободна подготовка за зрелостници</small>
          </span>
        </a>

        <nav class="topnav" aria-label="Основна навигация">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "topnav-link",
                  {
                    active:
                      pathname === item.href ||
                      (item.href !== "/" && pathname.startsWith(item.href)),
                  },
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>

      <main class="page-flow">
        <slot />
      </main>

      <footer class="site-footer">
        <p>Свободна библиотека за литература и български език преди ДЗИ.</p>
        <p>
          <a href="https://www.instagram.com/dttdrv/" target="_blank" rel="noreferrer">
            създадено от @dttdrv
          </a>
        </p>
      </footer>
    </div>
  </body>
</html>
