---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Literata:opsz,wght@7..72,400;7..72,700&family=Manrope:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="site-shell">
      <header class="nav" id="site-nav">
        <a href="/" class="nav-brand" aria-label="ДЗИ библиотека">ДЗИ по БЕЛ</a>
        <button class="nav-search" aria-label="Търсене" data-search-toggle>⌕</button>
      </header>

      <div class="nav-spacer" aria-hidden="true"></div>

      <main>
        <slot />
      </main>

      <footer class="footer">
        <span class="footer-credit">
          Направено от <a href="https://www.instagram.com/dttdrv/" target="_blank" rel="noreferrer">@dttdrv</a>
        </span>
      </footer>
    </div>
    <script>
      import "../scripts/interactions";
    </script>
  </body>
</html>
