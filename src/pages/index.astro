---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";
import { buildLibraryIndex } from "../lib/library";

const literatureEntries: CollectionEntry<"literature">[] = (
  await getCollection("literature")
).sort(
  (left: CollectionEntry<"literature">, right: CollectionEntry<"literature">) =>
    left.data.order - right.data.order,
);
const grammarEntries: CollectionEntry<"grammar">[] = (
  await getCollection("grammar")
).sort(
  (left: CollectionEntry<"grammar">, right: CollectionEntry<"grammar">) =>
    left.data.order - right.data.order,
);

const libraryItems = buildLibraryIndex({
  literature: literatureEntries,
  grammar: grammarEntries,
});

const themeCounts = new Map<string, number>();
for (const entry of literatureEntries) {
  themeCounts.set(entry.data.theme, (themeCounts.get(entry.data.theme) ?? 0) + 1);
}
const topThemes = [...themeCounts.entries()].sort((left, right) => right[1] - left[1]);
---

<BaseLayout
  title="ДЗИ библиотека"
  description="Свободна библиотека за литература и български език преди ДЗИ."
  pathname={Astro.url.pathname}
>
  <section class="band band--home">
    <div class="hero-grid">
      <article class="hero-column reveal">
        <p class="kicker">Безплатна подготовка за ДЗИ</p>
        <h1 class="display-title">
          Подреди материала. Намери правилния текст. Влез по-спокоен в изпита.
        </h1>
        <p class="lede">
          Дигитална читалня за 12. клас с произведения, теми, мотиви, граматика и
          директни линкове към пълните текстове. Всичко е подредено за бързо търсене,
          а не за хаотично скролване преди матурата.
        </p>

        <div class="cta-row">
          <a class="button" href="/literatura/">Отвори литературата</a>
          <a class="ghost-link ghost-link--secondary" href="/bulgarski/">
            Отвори българския език
          </a>
        </div>

        <div class="metric-board stagger">
          <div class="metric">
            <strong class="metric-value">{literatureEntries.length}</strong>
            <span class="metric-label">произведения с подредени теми, мотиви и контекст</span>
          </div>
          <div class="metric">
            <strong class="metric-value">{grammarEntries.length}</strong>
            <span class="metric-label">модула по български език за последен преговор</span>
          </div>
          <div class="metric">
            <strong class="metric-value">{libraryItems.length}</strong>
            <span class="metric-label">общо записа в библиотеката</span>
          </div>
          <div class="metric">
            <strong class="metric-value">0 лв.</strong>
            <span class="metric-label">свободен достъп без регистрация</span>
          </div>
        </div>
      </article>

      <aside class="hero-column reveal reveal-delay-1">
        <div class="hero-rail">
          <p class="kicker">Какво има вътре</p>
          <h2 class="rail-title">Една спокойна дигитална читалня, а не още един шумен сайт.</h2>
          <ul class="rail-list">
            <li>Литература с автор, тема, жанр, мотиви, конфликти и бутон към пълния текст.</li>
            <li>Български език в кратки модули, които се сканират лесно и на телефон.</li>
            <li>Автоматичен светъл и тъмен режим според устройството, без тежки ефекти.</li>
          </ul>
        </div>

        <div class="block">
          <p class="kicker">Бърз маршрут</p>
          <h3 class="block-title">Започни от това, което ти гори най-много.</h3>
          <div class="stack-row">
            <span class="pill">търсене</span>
            <span class="pill pill--secondary">филтри</span>
            <span class="pill">четене</span>
          </div>
          <p class="body-copy">
            Ако помниш автора, темата или само едно правило, ще стигнеш до правилната
            страница за секунди.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="surface reveal" data-search-root>
    <div class="surface-header">
      <div class="surface-header-copy">
        <p class="kicker">Глобално търсене</p>
        <h2 class="section-title">Потърси произведение, автор, тема или правило.</h2>
      </div>
      <p class="result-summary" data-result-summary>{libraryItems.length} резултата</p>
    </div>

    <div class="catalog-toolbar">
      <div class="toolbar-row">
        <label class="toolbar-field">
          <span class="toolbar-label">Търси в библиотеката</span>
          <input
            class="toolbar-input"
            type="search"
            placeholder="Например: Вапцаров, любов, запетая"
            data-search-input
          />
        </label>

        <label class="toolbar-field toolbar-field--compact">
          <span class="toolbar-label">Раздел</span>
          <select class="toolbar-select" data-type-filter>
            <option value="all">Всички</option>
            <option value="literature">Литература</option>
            <option value="grammar">Български език</option>
          </select>
        </label>
      </div>
    </div>

    <div class="catalog-grid stagger">
      {
        libraryItems.map((item, index) => (
          <a
            href={item.href}
            class="card"
            data-card
            data-type={item.type}
            data-search-text={item.searchText}
          >
            <div class="card-shell">
              <div class="card-topline">
                <span class:list={["pill", item.type === "grammar" && "pill--secondary"]}>
                  {item.category}
                </span>
                <span class="card-index">{String(index + 1).padStart(2, "0")}</span>
              </div>
              <h3 class="card-title" data-card-title>{item.title}</h3>
              <p class="card-meta">{item.meta}</p>
              <p class="card-copy">{item.description}</p>
            </div>
          </a>
        ))
      }
    </div>

    <p class="empty-state" data-empty-state hidden>
      Няма съвпадения. Пробвай с друго име, тема или термин.
    </p>
  </section>

  <section class="surface reveal">
    <div class="surface-header">
      <div class="surface-header-copy">
        <p class="kicker">Двата основни рафта</p>
        <h2 class="section-title">Започни от правилната посока, вместо от случайна страница.</h2>
      </div>
    </div>

    <div class="split-band">
      <article class="block">
        <p class="kicker">Литература</p>
        <h3 class="block-title">Произведенията са подредени по теми, автори и мотиви.</h3>
        <p class="block-copy">
          Всеки текст има собствена страница с акцент върху най-важното за матурата и
          ясен бутон към пълното произведение.
        </p>
        <div class="cta-row">
          <a class="button" href="/literatura/">Към произведенията</a>
        </div>
      </article>

      <article class="block">
        <p class="kicker">Български език</p>
        <h3 class="block-title">Морфология, синтаксис и правопис в кратък преговорен формат.</h3>
        <p class="block-copy">
          Модулите са замислени за последните дни преди изпита, когато ти трябва структура,
          а не още хаос.
        </p>
        <div class="cta-row">
          <a class="ghost-link ghost-link--secondary" href="/bulgarski/">
            Към българския език
          </a>
        </div>
      </article>
    </div>
  </section>

  <section class="duo-grid">
    <article class="surface reveal">
      <div class="surface-header">
        <div class="surface-header-copy">
          <p class="kicker">Литература</p>
          <h2 class="section-title">Най-важните теми в програмата.</h2>
        </div>
      </div>

      <div class="catalog-grid stagger">
        {
          topThemes.map(([theme, count], index) => (
            <a href="/literatura/" class="card">
              <div class="card-shell">
                <div class="card-topline">
                  <span class="pill">Тема</span>
                  <span class="card-index">{String(index + 1).padStart(2, "0")}</span>
                </div>
                <h3 class="card-title">{theme}</h3>
                <p class="card-copy">{count} произведения</p>
              </div>
            </a>
          ))
        }
      </div>
    </article>

    <article class="surface reveal reveal-delay-1">
      <div class="surface-header">
        <div class="surface-header-copy">
          <p class="kicker">Български език</p>
          <h2 class="section-title">Модулите за бърз финален преговор.</h2>
        </div>
      </div>

      <div class="catalog-grid stagger">
        {
          grammarEntries.map((entry, index) => (
            <a href={`/bulgarski/${entry.id}/`} class="card" data-module={entry.data.module}>
              <div class="card-shell">
                <div class="card-topline">
                  <span class="pill pill--secondary">{entry.data.module}</span>
                  <span class="card-index">{String(index + 1).padStart(2, "0")}</span>
                </div>
                <h3 class="card-title">{entry.data.title}</h3>
                <p class="card-copy">{entry.data.excerpt}</p>
              </div>
            </a>
          ))
        }
      </div>
    </article>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const initSearch = () => {
      const root = document.querySelector("[data-search-root]");
      if (!(root instanceof HTMLElement) || root.dataset.enhanced === "true") return;

      root.dataset.enhanced = "true";

      const searchInput = root.querySelector("[data-search-input]");
      const typeFilter = root.querySelector("[data-type-filter]");
      const cards = Array.from(root.querySelectorAll("[data-card]"));
      const summary = root.querySelector("[data-result-summary]");
      const emptyState = root.querySelector("[data-empty-state]");

      if (!(searchInput instanceof HTMLInputElement)) return;
      if (!(typeFilter instanceof HTMLSelectElement)) return;
      if (!(summary instanceof HTMLElement)) return;
      if (!(emptyState instanceof HTMLElement)) return;

      const label = (count) => `${count} ${count === 1 ? "резултат" : "резултата"}`;

      const applyFilters = () => {
        const query = searchInput.value.trim().toLocaleLowerCase("bg-BG");
        const type = typeFilter.value;
        let visible = 0;

        for (const card of cards) {
          if (!(card instanceof HTMLElement)) continue;

          const matchesQuery = !query || card.dataset.searchText?.includes(query);
          const matchesType = type === "all" || card.dataset.type === type;
          const show = Boolean(matchesQuery && matchesType);

          card.hidden = !show;
          if (show) visible += 1;
        }

        summary.textContent = label(visible);
        emptyState.hidden = visible !== 0;
      };

      searchInput.addEventListener("input", applyFilters);
      typeFilter.addEventListener("change", applyFilters);
      applyFilters();
    };

    initSearch();
    document.addEventListener("astro:page-load", initSearch, { once: true });
  })();
</script>
