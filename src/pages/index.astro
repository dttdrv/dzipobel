---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const literatureEntries: CollectionEntry<"literature">[] = (
  await getCollection("literature")
).sort(
  (a: CollectionEntry<"literature">, b: CollectionEntry<"literature">) =>
    a.data.order - b.data.order,
);

const grammarEntries: CollectionEntry<"grammar">[] = (
  await getCollection("grammar")
).sort(
  (a: CollectionEntry<"grammar">, b: CollectionEntry<"grammar">) =>
    a.data.order - b.data.order,
);

/* Derive grade from theme */
const grade11Themes = ["Родното и чуждото", "Миналото и паметта", "Обществото и властта", "Животът и смъртта", "Природата"];
function getGrade(theme: string): string {
  return grade11Themes.includes(theme) ? "11 клас" : "12 клас";
}

/* Sort chronologically by author birth year (approximated by order) */
const sortedLitEntries = [...literatureEntries].sort((a, b) => a.data.order - b.data.order);

const themes = [...new Set(sortedLitEntries.map((e) => e.data.theme))];
const authors = [...new Set(sortedLitEntries.map((e) => e.data.author))];
const genres = [...new Set(sortedLitEntries.map((e) => e.data.genre))];

/* Grouped grammar modules with human-friendly descriptions */
type GrammarGroup = {
  label: string;
  hint: string;
  modules: string[];
};

const grammarGroups: GrammarGroup[] = [
  {
    label: "Език",
    hint: "Звукове, думи, правопис и значение",
    modules: ["Фонетика", "Морфология", "Словообразуване", "Правопис", "Лексикология"],
  },
  {
    label: "Текст и писане",
    hint: "Изречения, стилове, текстове и подготовка за изпита",
    modules: ["Синтаксис", "Стилистика", "Текстолингвистика", "Създаване на текст"],
  },
];

const humanNames: Record<string, string> = {
  "Фонетика": "Звукове, срички и ударения",
  "Морфология": "Частите на речта и формите им",
  "Словообразуване": "Как се образуват нови думи",
  "Синтаксис": "Видове изречения и препинателни знаци",
  "Стилистика": "Стилове, тропи и фигури",
  "Текстолингвистика": "Видове текстове и как се изграждат",
  "Правопис": "Правилно изписване на думите",
  "Лексикология": "Значение на думите, синоними, пароними",
  "Създаване на текст": "Как се пише есе и съчинение за ДЗИ",
};

function findEntry(module: string) {
  return grammarEntries.find((e) => e.data.module === module);
}

type DropdownOption = { value: string; label: string };

const themeOptions: DropdownOption[] = themes.map((t) => ({ value: t, label: t }));
const authorOptions: DropdownOption[] = authors.map((a) => ({ value: a, label: a }));
const genreOptions: DropdownOption[] = genres.map((g) => ({ value: g, label: g }));
---

<BaseLayout title="ДЗИ библиотека" description="Безплатна библиотека с литература и български език преди ДЗИ.">

  <!-- HERO -->
  <section class="hero">
    <h1 class="hero-headline" data-scroll-sentinel>Подготовка за ДЗИ по БЕЛ</h1>
    <p class="hero-sub">Произведения и граматика за държавен зрелостен изпит.</p>
  </section>

  <!-- STUDY FINDER -->
  <div class="finder">
    <div class="switcher-bar">
      <div class="switcher" data-switcher>
        <div class="switcher-pill" data-pill data-pos="0"></div>
        <button class="switcher-btn active" data-switch="literature">Литература</button>
        <button class="switcher-btn" data-switch="grammar">Български език</button>
      </div>
    </div>
  </div>

  <!-- LITERATURE -->
  <section class="section" data-section="literature">
    <div class="filter-bar" data-filters>
      <div class="filter-group">
        <span class="filter-group-label">Клас</span>
        <div class="filter-segment">
          <button class="filter-segment-btn active" data-grade-filter="">Всички</button>
          <button class="filter-segment-btn" data-grade-filter="11 клас">11</button>
          <button class="filter-segment-btn" data-grade-filter="12 клас">12</button>
        </div>
      </div>

      <div class="filter-dropdowns">
        <div class="dropdown" data-dropdown data-filter-type="theme">
          <button type="button" class="dropdown-trigger" data-dropdown-trigger aria-haspopup="listbox" aria-expanded="false">
            <span class="dropdown-trigger-label">Тема</span>
            <span class="dropdown-trigger-value" data-dropdown-value></span>
            <svg class="dropdown-caret" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          <div class="dropdown-panel" role="listbox" data-dropdown-panel>
            <button type="button" role="option" class="dropdown-option dropdown-option--active" data-dropdown-option="">Всички</button>
            {themeOptions.map((opt) => (
              <button type="button" role="option" class="dropdown-option" data-dropdown-option={opt.value}>{opt.label}</button>
            ))}
          </div>
        </div>

        <div class="dropdown" data-dropdown data-filter-type="author">
          <button type="button" class="dropdown-trigger" data-dropdown-trigger aria-haspopup="listbox" aria-expanded="false">
            <span class="dropdown-trigger-label">Автор</span>
            <span class="dropdown-trigger-value" data-dropdown-value></span>
            <svg class="dropdown-caret" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          <div class="dropdown-panel" role="listbox" data-dropdown-panel>
            <button type="button" role="option" class="dropdown-option dropdown-option--active" data-dropdown-option="">Всички</button>
            {authorOptions.map((opt) => (
              <button type="button" role="option" class="dropdown-option" data-dropdown-option={opt.value}>{opt.label}</button>
            ))}
          </div>
        </div>

        <div class="dropdown" data-dropdown data-filter-type="genre">
          <button type="button" class="dropdown-trigger" data-dropdown-trigger aria-haspopup="listbox" aria-expanded="false">
            <span class="dropdown-trigger-label">Жанр</span>
            <span class="dropdown-trigger-value" data-dropdown-value></span>
            <svg class="dropdown-caret" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          <div class="dropdown-panel" role="listbox" data-dropdown-panel>
            <button type="button" role="option" class="dropdown-option dropdown-option--active" data-dropdown-option="">Всички</button>
            {genreOptions.map((opt) => (
              <button type="button" role="option" class="dropdown-option" data-dropdown-option={opt.value}>{opt.label}</button>
            ))}
          </div>
        </div>
      </div>
    </div>
    <div class="lit-list">
      {sortedLitEntries.map((entry) => {
        const grade = getGrade(entry.data.theme);
        return (
          <a
            href={`/literatura/${entry.id}/`}
            class="lit-list-item"
            data-card
            data-nav-card="literature"
            data-theme={entry.data.theme}
            data-author={entry.data.author}
            data-genre={entry.data.genre}
            data-grade={grade}
          >
            <span class="lit-list-title" transition:name={`title-${entry.id}`}>{entry.data.title}</span>
            <span class="lit-list-meta">{entry.data.author} · {entry.data.genre}</span>
            <span class="lit-list-theme">{grade} · {entry.data.theme}</span>
          </a>
        );
      })}
    </div>
    <p class="empty-state" data-empty hidden>Няма произведения по тези критерии.</p>
  </section>

  <!-- GRAMMAR: GROUPED NAV -->
  <section class="section" data-section="grammar" hidden>
    <div class="gram-groups">
      {grammarGroups.map((group) => (
        <div class="gram-group">
          <div class="gram-group-head">
            <span class="gram-group-label">{group.label}</span>
            <span class="gram-group-hint">{group.hint}</span>
          </div>
          <div class="gram-group-items">
            {group.modules.map((mod) => {
              const entry = findEntry(mod);
              if (!entry) return null;
              return (
                <a
                  href={`/bulgarski/${entry.id}/`}
                  class="gram-item"
                  data-card
                  data-nav-card="grammar"
                >
                  <span class="gram-item-title" transition:name={`title-${entry.id}`}>{entry.data.title}</span>
                  <span class="gram-item-sub">{humanNames[mod] || entry.data.excerpt}</span>
                  <span class="gram-item-count">{entry.data.sections.length} раздела</span>
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>
    <p class="empty-state" data-empty hidden>Няма граматични модули по тази дума.</p>
  </section>

</BaseLayout>

<script is:inline>
  (() => {
    const STATE_KEY = "__landingState";

    const restoreLandingState = () => {
      let restore = null;
      try {
        const flag = sessionStorage.getItem("__restoreOnLand");
        const raw = sessionStorage.getItem(STATE_KEY);
        if (flag === "true" && raw) {
          restore = JSON.parse(raw);
        }
        sessionStorage.removeItem("__restoreOnLand");
      } catch {}
      return restore;
    };

    const saveLandingState = (tab, filters, scroll) => {
      try {
        sessionStorage.setItem(STATE_KEY, JSON.stringify({ tab, filters, scroll }));
      } catch {}
    };

    const initLanding = () => {
      const switcher = document.querySelector("[data-switcher]");
      if (!(switcher instanceof HTMLElement) || switcher.dataset.enhanced === "true") return;
      switcher.dataset.enhanced = "true";

      const switcherBtns = Array.from(switcher.querySelectorAll("[data-switch]"));
      const litSection = document.querySelector('[data-section="literature"]');
      const gramSection = document.querySelector('[data-section="grammar"]');
      const litEmpty = litSection?.querySelector("[data-empty]");
      const gramEmpty = gramSection?.querySelector("[data-empty]");

      if (!(litSection instanceof HTMLElement)) return;
      if (!(gramSection instanceof HTMLElement)) return;

      const dropdowns = Array.from(litSection.querySelectorAll("[data-dropdown]"));
      const gradeBtns = Array.from(litSection.querySelectorAll("[data-grade-filter]"));
      const litCards = Array.from(litSection.querySelectorAll("[data-card]"));
      const gramCards = Array.from(gramSection.querySelectorAll("[data-card]"));
      const litList = litSection.querySelector(".lit-list");

      const grade11Themes = ["Родното и чуждото", "Миналото и паметта", "Обществото и властта", "Животът и смъртта", "Природата"];

      let activeTab = "literature";
      const activeFilters = { grade: "", theme: "", author: "", genre: "" };

      /* Update theme options visibility based on grade */
      const updateThemeOptions = () => {
        const themeDropdown = dropdowns.find((d) => d.getAttribute("data-filter-type") === "theme");
        if (!themeDropdown) return;
        const opts = themeDropdown.querySelectorAll("[data-dropdown-option]");
        for (const opt of opts) {
          if (!(opt instanceof HTMLElement)) continue;
          const value = opt.getAttribute("data-dropdown-option") || "";
          if (!value) continue;
          const isGrade11Theme = grade11Themes.includes(value);
          if (activeFilters.grade === "11 клас") {
            opt.hidden = !isGrade11Theme;
          } else if (activeFilters.grade === "12 клас") {
            opt.hidden = isGrade11Theme;
          } else {
            opt.hidden = false;
          }
        }
        // Reset hidden current theme
        if (activeFilters.theme) {
          const isGrade11Theme = grade11Themes.includes(activeFilters.theme);
          const out =
            (activeFilters.grade === "11 клас" && !isGrade11Theme) ||
            (activeFilters.grade === "12 клас" && isGrade11Theme);
          if (out) {
            activeFilters.theme = "";
            setDropdownValue(themeDropdown, "", "Тема");
          }
        }
      };

      const setDropdownValue = (dropdown, value, fallbackLabel) => {
        const valueEl = dropdown.querySelector("[data-dropdown-value]");
        const labelEl = dropdown.querySelector(".dropdown-trigger-label");
        const opts = dropdown.querySelectorAll("[data-dropdown-option]");
        for (const opt of opts) {
          if (opt instanceof HTMLElement) {
            opt.classList.toggle("dropdown-option--active", (opt.getAttribute("data-dropdown-option") || "") === value);
          }
        }
        if (value) {
          if (valueEl instanceof HTMLElement) valueEl.textContent = value;
          if (labelEl instanceof HTMLElement) labelEl.dataset.hasValue = "true";
        } else {
          if (valueEl instanceof HTMLElement) valueEl.textContent = "";
          if (labelEl instanceof HTMLElement) {
            labelEl.dataset.hasValue = "false";
            labelEl.textContent = fallbackLabel;
          }
        }
      };

      const labelFor = (type) => type === "theme" ? "Тема" : type === "author" ? "Автор" : "Жанр";

      const closeAllDropdowns = (except) => {
        for (const d of dropdowns) {
          if (d === except) continue;
          d.dataset.open = "false";
          const t = d.querySelector("[data-dropdown-trigger]");
          if (t instanceof HTMLElement) t.setAttribute("aria-expanded", "false");
        }
      };

      const applyFilters = () => {
        const cards = activeTab === "literature" ? litCards : gramCards;
        let visible = 0;

        for (const card of cards) {
          if (!(card instanceof HTMLElement)) continue;
          const matchesGrade = !activeFilters.grade || card.dataset.grade === activeFilters.grade;
          const matchesTheme = !activeFilters.theme || card.dataset.theme === activeFilters.theme;
          const matchesAuthor = !activeFilters.author || card.dataset.author === activeFilters.author;
          const matchesGenre = !activeFilters.genre || card.dataset.genre === activeFilters.genre;

          const show = activeTab === "literature"
            ? (matchesGrade && matchesTheme && matchesAuthor && matchesGenre)
            : true;
          card.hidden = !show;
          if (show) visible += 1;
        }

        const empty = activeTab === "literature" ? litEmpty : gramEmpty;
        if (empty instanceof HTMLElement) empty.hidden = visible !== 0;

        if (activeTab === "literature" && litList instanceof HTMLElement) {
          litList.classList.add("lit-list--settling");
          requestAnimationFrame(() => {
            requestAnimationFrame(() => litList.classList.remove("lit-list--settling"));
          });
        }
      };

      /* Switcher */
      const pill = document.querySelector("[data-pill]");
      const switchTo = (tab, instant) => {
        if (tab === activeTab) return;
        const goingRight = tab === "grammar";
        const outgoing = goingRight ? litSection : gramSection;
        const incoming = goingRight ? gramSection : litSection;

        if (pill instanceof HTMLElement) pill.dataset.pos = goingRight ? "1" : "0";
        for (const b of switcherBtns) {
          if (b instanceof HTMLElement) b.classList.toggle("active", b.dataset.switch === tab);
        }

        if (instant) {
          outgoing.hidden = true;
          incoming.hidden = false;
          activeTab = tab;
          return;
        }

        outgoing.classList.add(goingRight ? "section--exit-left" : "section--exit-right");
        setTimeout(() => {
          outgoing.hidden = true;
          outgoing.classList.remove("section--exit-left", "section--exit-right");
          incoming.hidden = false;
          incoming.classList.add(goingRight ? "section--enter-right" : "section--enter-left");
          setTimeout(() => incoming.classList.remove("section--enter-left", "section--enter-right"), 350);
        }, 250);

        activeTab = tab;
      };

      for (const btn of switcherBtns) {
        if (!(btn instanceof HTMLElement)) continue;
        btn.addEventListener("click", () => {
          const tab = btn.dataset.switch || "literature";
          if (tab === activeTab) return;
          // Reset filters on user-initiated tab switch
          activeFilters.grade = "";
          activeFilters.theme = "";
          activeFilters.author = "";
          activeFilters.genre = "";
          for (const d of dropdowns) {
            const type = d.getAttribute("data-filter-type") || "";
            setDropdownValue(d, "", labelFor(type));
          }
          for (const b of gradeBtns) {
            if (b instanceof HTMLElement) b.classList.toggle("active", (b.dataset.gradeFilter || "") === "");
          }
          updateThemeOptions();
          switchTo(tab, false);
          applyFilters();
        });
      }

      /* Grade toggle */
      for (const btn of gradeBtns) {
        if (!(btn instanceof HTMLElement)) continue;
        btn.addEventListener("click", () => {
          activeFilters.grade = btn.dataset.gradeFilter || "";
          for (const b of gradeBtns) {
            if (b instanceof HTMLElement) b.classList.toggle("active", (b.dataset.gradeFilter || "") === activeFilters.grade);
          }
          updateThemeOptions();
          applyFilters();
        });
      }

      /* Custom dropdowns */
      for (const dropdown of dropdowns) {
        if (!(dropdown instanceof HTMLElement)) continue;
        const trigger = dropdown.querySelector("[data-dropdown-trigger]");
        const type = dropdown.getAttribute("data-filter-type") || "";
        const opts = dropdown.querySelectorAll("[data-dropdown-option]");

        if (trigger instanceof HTMLElement) {
          trigger.addEventListener("click", (e) => {
            e.stopPropagation();
            const open = dropdown.dataset.open === "true";
            closeAllDropdowns(dropdown);
            dropdown.dataset.open = open ? "false" : "true";
            trigger.setAttribute("aria-expanded", open ? "false" : "true");
          });
        }

        for (const opt of opts) {
          if (!(opt instanceof HTMLElement)) continue;
          opt.addEventListener("click", (e) => {
            e.stopPropagation();
            const value = opt.getAttribute("data-dropdown-option") || "";
            activeFilters[type] = value;
            setDropdownValue(dropdown, value, labelFor(type));
            dropdown.dataset.open = "false";
            if (trigger instanceof HTMLElement) trigger.setAttribute("aria-expanded", "false");
            applyFilters();
          });
        }
      }

      // Close dropdowns on outside click / Escape
      document.addEventListener("click", () => closeAllDropdowns(null));
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeAllDropdowns(null);
      });

      /* Save state when navigating to a detail page */
      const navCards = document.querySelectorAll("[data-nav-card]");
      for (const card of navCards) {
        if (!(card instanceof HTMLElement)) continue;
        card.addEventListener("click", () => {
          saveLandingState(activeTab, { ...activeFilters }, window.scrollY);
        });
      }

      /* Restore landing state if user just navigated back */
      const restore = restoreLandingState();
      if (restore) {
        if (restore.tab && restore.tab !== activeTab) {
          switchTo(restore.tab, true);
        }
        if (restore.filters) {
          activeFilters.grade = restore.filters.grade || "";
          activeFilters.theme = restore.filters.theme || "";
          activeFilters.author = restore.filters.author || "";
          activeFilters.genre = restore.filters.genre || "";

          for (const b of gradeBtns) {
            if (b instanceof HTMLElement) b.classList.toggle("active", (b.dataset.gradeFilter || "") === activeFilters.grade);
          }
          for (const d of dropdowns) {
            const type = d.getAttribute("data-filter-type") || "";
            setDropdownValue(d, activeFilters[type] || "", labelFor(type));
          }
          updateThemeOptions();
        }
        applyFilters();
        // Scroll restore after layout settles
        requestAnimationFrame(() => {
          window.scrollTo({ top: restore.scroll || 0, left: 0, behavior: "instant" });
        });
      } else {
        applyFilters();
      }
    };

    initLanding();
    document.addEventListener("astro:page-load", initLanding);
  })();
</script>
