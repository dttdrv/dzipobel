---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const literatureEntries: CollectionEntry<"literature">[] = (
  await getCollection("literature")
).sort(
  (a: CollectionEntry<"literature">, b: CollectionEntry<"literature">) =>
    a.data.order - b.data.order,
);

const grammarEntries: CollectionEntry<"grammar">[] = (
  await getCollection("grammar")
).sort(
  (a: CollectionEntry<"grammar">, b: CollectionEntry<"grammar">) =>
    a.data.order - b.data.order,
);

/* Derive grade from theme */
const grade11Themes = ["Родното и чуждото", "Миналото и паметта", "Обществото и властта", "Животът и смъртта", "Природата"];
function getGrade(theme: string): string {
  return grade11Themes.includes(theme) ? "11 клас" : "12 клас";
}

/* Sort chronologically by author birth year (approximated by order) */
const sortedLitEntries = [...literatureEntries].sort((a, b) => a.data.order - b.data.order);

const themes = [...new Set(sortedLitEntries.map((e) => e.data.theme))];
const authors = [...new Set(sortedLitEntries.map((e) => e.data.author))];
const genres = [...new Set(sortedLitEntries.map((e) => e.data.genre))];

/* Grouped grammar modules with human-friendly descriptions */
type GrammarGroup = {
  label: string;
  hint: string;
  modules: string[]; // module field values
};

const grammarGroups: GrammarGroup[] = [
  {
    label: "Език",
    hint: "Звукове, думи, правопис и значение",
    modules: ["Фонетика", "Морфология", "Словообразуване", "Правопис", "Лексикология"],
  },
  {
    label: "Текст и писане",
    hint: "Изречения, стилове, текстове и подготовка за изпита",
    modules: ["Синтаксис", "Стилистика", "Текстолингвистика", "Създаване на текст"],
  },
];

const humanNames: Record<string, string> = {
  "Фонетика": "Звукове, срички и ударения",
  "Морфология": "Частите на речта и формите им",
  "Словообразуване": "Как се образуват нови думи",
  "Синтаксис": "Видове изречения и препинателни знаци",
  "Стилистика": "Стилове, тропи и фигури",
  "Текстолингвистика": "Видове текстове и как се изграждат",
  "Правопис": "Правилно изписване на думите",
  "Лексикология": "Значение на думите, синоними, пароними",
  "Създаване на текст": "Как се пише есе и съчинение за ДЗИ",
};

function findEntry(module: string) {
  return grammarEntries.find((e) => e.data.module === module);
}
---

<BaseLayout title="ДЗИ библиотека" description="Безплатна библиотека с литература и български език преди ДЗИ.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-orb hero-orb--1" aria-hidden="true"></div>
    <div class="hero-orb hero-orb--2" aria-hidden="true"></div>
    <h1 class="hero-headline">Подготви се<br>за матурата.</h1>
    <p class="hero-sub">Безплатна библиотека с произведения и граматика за ДЗИ.</p>
  </section>

  <!-- SWITCHER -->
  <div class="switcher-bar">
    <div class="switcher" data-switcher>
      <div class="switcher-pill" data-pill data-pos="0"></div>
      <button class="switcher-btn active" data-switch="literature">Литература</button>
      <button class="switcher-btn" data-switch="grammar">Български език</button>
    </div>
  </div>

  <!-- LITERATURE (filters + list together so they slide as one) -->
  <section class="section" data-section="literature">
    <div class="filter-dropdowns" data-filters>
      <select class="filter-select" data-filter-type="grade">
        <option value="">Всички класове</option>
        <option value="11 клас">11 клас</option>
        <option value="12 клас">12 клас</option>
      </select>
      <select class="filter-select" data-filter-type="theme">
        <option value="">Всички теми</option>
        {themes.map((theme) => (
          <option value={theme}>{theme}</option>
        ))}
      </select>
      <select class="filter-select" data-filter-type="author">
        <option value="">Всички автори</option>
        {authors.map((author) => (
          <option value={author}>{author}</option>
        ))}
      </select>
      <select class="filter-select" data-filter-type="genre">
        <option value="">Всички жанрове</option>
        {genres.map((genre) => (
          <option value={genre}>{genre}</option>
        ))}
      </select>
    </div>
    <div class="lit-list">
      {sortedLitEntries.map((entry) => {
        const grade = getGrade(entry.data.theme);
        return (
          <a
            href={`/literatura/${entry.id}/`}
            class="lit-list-item"
            data-card
            data-theme={entry.data.theme}
            data-author={entry.data.author}
            data-genre={entry.data.genre}
            data-grade={grade}
            data-search-text={`${entry.data.title} ${entry.data.author} ${entry.data.genre} ${entry.data.theme} ${grade} ${entry.data.tags.join(" ")}`.toLocaleLowerCase("bg-BG")}
          >
            <span class="lit-list-title" transition:name={`title-${entry.id}`}>{entry.data.title}</span>
            <span class="lit-list-meta">{entry.data.author} · {entry.data.genre}</span>
            <span class="lit-list-theme">{grade} · {entry.data.theme}</span>
          </a>
        );
      })}
    </div>
    <p class="empty-state" data-empty hidden>Няма резултати.</p>
  </section>

  <!-- GRAMMAR: GROUPED NAV -->
  <section class="section" data-section="grammar" hidden>
    <div class="gram-groups">
      {grammarGroups.map((group) => (
        <div class="gram-group">
          <div class="gram-group-head">
            <span class="gram-group-label">{group.label}</span>
            <span class="gram-group-hint">{group.hint}</span>
          </div>
          <div class="gram-group-items">
            {group.modules.map((mod) => {
              const entry = findEntry(mod);
              if (!entry) return null;
              return (
                <a
                  href={`/bulgarski/${entry.id}/`}
                  class="gram-item"
                  data-card
                  data-search-text={`${entry.data.title} ${entry.data.module} ${entry.data.excerpt} ${entry.data.tags.join(" ")} ${humanNames[mod] || ""}`.toLocaleLowerCase("bg-BG")}
                >
                  <span class="gram-item-title" transition:name={`title-${entry.id}`}>{entry.data.title}</span>
                  <span class="gram-item-sub">{humanNames[mod] || entry.data.excerpt}</span>
                  <span class="gram-item-count">{entry.data.sections.length} раздела</span>
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>
    <p class="empty-state" data-empty hidden>Няма резултати.</p>
  </section>

</BaseLayout>

<script is:inline>
  (() => {
    const initLanding = () => {
      const switcher = document.querySelector("[data-switcher]");
      if (!(switcher instanceof HTMLElement) || switcher.dataset.enhanced === "true") return;
      switcher.dataset.enhanced = "true";

      const switcherBtns = Array.from(switcher.querySelectorAll("[data-switch]"));
      const litSection = document.querySelector('[data-section="literature"]');
      const gramSection = document.querySelector('[data-section="grammar"]');
      const emptyState = document.querySelector("[data-empty]");

      if (!(litSection instanceof HTMLElement)) return;
      if (!(gramSection instanceof HTMLElement)) return;
      if (!(emptyState instanceof HTMLElement)) return;

      const filterSelects = Array.from(litSection.querySelectorAll("select[data-filter-type]"));
      const litCards = Array.from(litSection.querySelectorAll("[data-card]"));
      const gramCards = Array.from(gramSection.querySelectorAll("[data-card]"));

      let activeTab = "literature";
      const activeFilters = { grade: "", theme: "", author: "", genre: "" };
      let searchQuery = "";

      const applyFilters = () => {
        const cards = activeTab === "literature" ? litCards : gramCards;
        let visible = 0;

        for (const card of cards) {
          if (!(card instanceof HTMLElement)) continue;

          const matchesGrade = !activeFilters.grade || card.dataset.grade === activeFilters.grade;
          const matchesTheme = !activeFilters.theme || card.dataset.theme === activeFilters.theme;
          const matchesAuthor = !activeFilters.author || card.dataset.author === activeFilters.author;
          const matchesGenre = !activeFilters.genre || card.dataset.genre === activeFilters.genre;
          const matchesSearch = !searchQuery || (card.dataset.searchText || "").includes(searchQuery);

          const show = activeTab !== "literature" || (matchesGrade && matchesTheme && matchesAuthor && matchesGenre && matchesSearch);
          card.hidden = !show;
          if (show) visible += 1;
        }

        emptyState.hidden = visible !== 0;
      };

      // Switcher with sliding pill and blur transition
      const pill = document.querySelector("[data-pill]");

      for (const btn of switcherBtns) {
        if (!(btn instanceof HTMLElement)) continue;
        btn.addEventListener("click", () => {
          const tab = btn.dataset.switch || "literature";
          if (tab === activeTab) return;

          // Direction: lit→bg = right, bg→lit = left
          const goingRight = tab === "grammar";
          const outgoing = goingRight ? litSection : gramSection;
          const incoming = goingRight ? gramSection : litSection;

          // Move the pill
          if (pill instanceof HTMLElement) {
            pill.dataset.pos = goingRight ? "1" : "0";
          }

          // Update button states
          for (const b of switcherBtns) {
            if (b instanceof HTMLElement) {
              b.classList.toggle("active", b.dataset.switch === tab);
            }
          }

          // Slide out old content in the direction of movement
          outgoing.classList.add(goingRight ? "section--exit-left" : "section--exit-right");

          // After exit finishes, swap and slide in new content from the other side
          setTimeout(() => {
            outgoing.hidden = true;
            outgoing.classList.remove("section--exit-left", "section--exit-right");

            incoming.hidden = false;
            incoming.classList.add(goingRight ? "section--enter-right" : "section--enter-left");

            // filters are inside litSection, no separate toggle needed

            setTimeout(() => {
              incoming.classList.remove("section--enter-left", "section--enter-right");
            }, 350);
          }, 250);

          activeTab = tab;

          // Reset filters on tab switch
          activeFilters.grade = "";
          activeFilters.theme = "";
          activeFilters.author = "";
          activeFilters.genre = "";
          for (const sel of filterSelects) {
            if (sel instanceof HTMLSelectElement) sel.value = "";
          }

          applyFilters();
        });
      }

      // Dropdown filters
      for (const sel of filterSelects) {
        if (!(sel instanceof HTMLSelectElement)) continue;
        sel.addEventListener("change", () => {
          const filterType = sel.dataset.filterType || "";
          activeFilters[filterType] = sel.value;
          applyFilters();
        });
      }

      // Search
      const handleSearch = (query) => {
        searchQuery = (query || "").trim().toLocaleLowerCase("bg-BG");
        applyFilters();
      };

      document.addEventListener("search-input", (e) => {
        if (e instanceof CustomEvent) {
          handleSearch(e.detail);
        }
      });

      const searchInput = document.querySelector("[data-search-input]");
      if (searchInput instanceof HTMLInputElement) {
        searchInput.addEventListener("input", () => {
          handleSearch(searchInput.value);
        });
      }

      applyFilters();
    };

    initLanding();
    document.addEventListener("astro:page-load", initLanding);
  })();
</script>
