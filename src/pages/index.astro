---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const literatureEntries: CollectionEntry<"literature">[] = (
  await getCollection("literature")
).sort(
  (a: CollectionEntry<"literature">, b: CollectionEntry<"literature">) =>
    a.data.order - b.data.order,
);

const grammarEntries: CollectionEntry<"grammar">[] = (
  await getCollection("grammar")
).sort(
  (a: CollectionEntry<"grammar">, b: CollectionEntry<"grammar">) =>
    a.data.order - b.data.order,
);

const themes = [...new Set(literatureEntries.map((e) => e.data.theme))];
const authors = [...new Set(literatureEntries.map((e) => e.data.author))];
const genres = [...new Set(literatureEntries.map((e) => e.data.genre))];

/* Grouped grammar modules with human-friendly descriptions */
type GrammarGroup = {
  label: string;
  hint: string;
  modules: string[]; // module field values
};

const grammarGroups: GrammarGroup[] = [
  {
    label: "Звук и дума",
    hint: "Как звучат и се образуват думите",
    modules: ["Фонетика", "Морфология", "Словообразуване"],
  },
  {
    label: "Изречение и текст",
    hint: "Как се свързват думите в смислен текст",
    modules: ["Синтаксис", "Стилистика", "Текстолингвистика"],
  },
  {
    label: "Правила за писане",
    hint: "Как се пише правилно",
    modules: ["Правопис", "Лексикология"],
  },
  {
    label: "Подготовка за изпита",
    hint: "Как да се справиш на матурата",
    modules: ["Създаване на текст"],
  },
];

const humanNames: Record<string, string> = {
  "Фонетика": "Звукове, срички и ударения",
  "Морфология": "Частите на речта и формите им",
  "Словообразуване": "Как се образуват нови думи",
  "Синтаксис": "Видове изречения и препинателни знаци",
  "Стилистика": "Стилове, тропи и фигури",
  "Текстолингвистика": "Видове текстове и как се изграждат",
  "Правопис": "Правилно изписване на думите",
  "Лексикология": "Значение на думите, синоними, пароними",
  "Създаване на текст": "Как се пише есе и съчинение за ДЗИ",
};

function findEntry(module: string) {
  return grammarEntries.find((e) => e.data.module === module);
}
---

<BaseLayout title="ДЗИ библиотека" description="Безплатна библиотека с литература и български език преди ДЗИ.">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-orb hero-orb--1" aria-hidden="true"></div>
    <div class="hero-orb hero-orb--2" aria-hidden="true"></div>
    <h1 class="hero-headline">Подготви се<br>за матурата.</h1>
    <p class="hero-sub">Безплатна библиотека с произведения и граматика за ДЗИ, 12 клас.</p>
  </section>

  <!-- SWITCHER -->
  <div class="switcher-bar">
    <div class="switcher" data-switcher>
      <button class="switcher-btn active" data-switch="literature">Литература</button>
      <button class="switcher-btn" data-switch="grammar">Български език</button>
    </div>
  </div>

  <!-- FILTER GROUPS (literature only) -->
  <div class="filter-groups" data-filters>
    <div class="filter-row">
      <span class="filter-row-label">Тема</span>
      <div class="filter-row-chips">
        <button class="filter-chip active" data-filter-type="theme" data-filter-value="">Всички</button>
        {themes.map((theme) => (
          <button class="filter-chip" data-filter-type="theme" data-filter-value={theme}>{theme}</button>
        ))}
      </div>
    </div>
    <div class="filter-row">
      <span class="filter-row-label">Автор</span>
      <div class="filter-row-chips">
        <button class="filter-chip active" data-filter-type="author" data-filter-value="">Всички</button>
        {authors.map((author) => (
          <button class="filter-chip" data-filter-type="author" data-filter-value={author}>{author}</button>
        ))}
      </div>
    </div>
    <div class="filter-row">
      <span class="filter-row-label">Жанр</span>
      <div class="filter-row-chips">
        <button class="filter-chip active" data-filter-type="genre" data-filter-value="">Всички</button>
        {genres.map((genre) => (
          <button class="filter-chip" data-filter-type="genre" data-filter-value={genre}>{genre}</button>
        ))}
      </div>
    </div>
  </div>

  <!-- LITERATURE CARDS -->
  <section class="section" data-section="literature">
    <div class="card-grid" data-card-grid>
      {literatureEntries.map((entry) => (
        <a
          href={`/literatura/${entry.id}/`}
          class="card-item"
          data-card
          data-theme={entry.data.theme}
          data-author={entry.data.author}
          data-genre={entry.data.genre}
          data-search-text={`${entry.data.title} ${entry.data.author} ${entry.data.genre} ${entry.data.theme} ${entry.data.tags.join(" ")}`.toLocaleLowerCase("bg-BG")}
        >
          <span class="card-genre">{entry.data.genre}</span>
          <h2 class="card-title" transition:name={`title-${entry.id}`}>{entry.data.title}</h2>
          <span class="card-author">{entry.data.author}</span>
        </a>
      ))}
    </div>
    <p class="empty-state" data-empty hidden>Няма резултати.</p>
  </section>

  <!-- GRAMMAR: GROUPED NAV -->
  <section class="section" data-section="grammar" hidden>
    <div class="gram-groups">
      {grammarGroups.map((group) => (
        <div class="gram-group">
          <div class="gram-group-head">
            <span class="gram-group-label">{group.label}</span>
            <span class="gram-group-hint">{group.hint}</span>
          </div>
          <div class="gram-group-items">
            {group.modules.map((mod) => {
              const entry = findEntry(mod);
              if (!entry) return null;
              return (
                <a
                  href={`/bulgarski/${entry.id}/`}
                  class="gram-item"
                  data-card
                  data-search-text={`${entry.data.title} ${entry.data.module} ${entry.data.excerpt} ${entry.data.tags.join(" ")} ${humanNames[mod] || ""}`.toLocaleLowerCase("bg-BG")}
                >
                  <span class="gram-item-title" transition:name={`title-${entry.id}`}>{entry.data.title}</span>
                  <span class="gram-item-sub">{humanNames[mod] || entry.data.excerpt}</span>
                  <span class="gram-item-count">{entry.data.sections.length} раздела</span>
                </a>
              );
            })}
          </div>
        </div>
      ))}
    </div>
    <p class="empty-state" data-empty hidden>Няма резултати.</p>
  </section>

</BaseLayout>

<script is:inline>
  (() => {
    const initLanding = () => {
      const switcher = document.querySelector("[data-switcher]");
      if (!(switcher instanceof HTMLElement) || switcher.dataset.enhanced === "true") return;
      switcher.dataset.enhanced = "true";

      const switcherBtns = Array.from(switcher.querySelectorAll("[data-switch]"));
      const litSection = document.querySelector('[data-section="literature"]');
      const gramSection = document.querySelector('[data-section="grammar"]');
      const filterBar = document.querySelector("[data-filters]");
      const emptyState = document.querySelector("[data-empty]");

      if (!(litSection instanceof HTMLElement)) return;
      if (!(gramSection instanceof HTMLElement)) return;
      if (!(filterBar instanceof HTMLElement)) return;
      if (!(emptyState instanceof HTMLElement)) return;

      const allFilterChips = Array.from(filterBar.querySelectorAll("[data-filter-type]"));
      const litCards = Array.from(litSection.querySelectorAll("[data-card]"));
      const gramCards = Array.from(gramSection.querySelectorAll("[data-card]"));

      let activeTab = "literature";
      const activeFilters = { theme: "", author: "", genre: "" };
      let searchQuery = "";

      const applyFilters = () => {
        const cards = activeTab === "literature" ? litCards : gramCards;
        let visible = 0;

        for (const card of cards) {
          if (!(card instanceof HTMLElement)) continue;

          const matchesTheme = !activeFilters.theme || card.dataset.theme === activeFilters.theme;
          const matchesAuthor = !activeFilters.author || card.dataset.author === activeFilters.author;
          const matchesGenre = !activeFilters.genre || card.dataset.genre === activeFilters.genre;
          const matchesSearch = !searchQuery || (card.dataset.searchText || "").includes(searchQuery);

          const show = activeTab !== "literature" || (matchesTheme && matchesAuthor && matchesGenre && matchesSearch);
          card.hidden = !show;
          if (show) visible += 1;
        }

        emptyState.hidden = visible !== 0;
      };

      // Switcher
      for (const btn of switcherBtns) {
        if (!(btn instanceof HTMLElement)) continue;
        btn.addEventListener("click", () => {
          const tab = btn.dataset.switch || "literature";
          if (tab === activeTab) return;

          activeTab = tab;

          for (const b of switcherBtns) {
            if (b instanceof HTMLElement) {
              b.classList.toggle("active", b.dataset.switch === tab);
            }
          }

          if (tab === "literature") {
            litSection.hidden = false;
            gramSection.hidden = true;
            filterBar.hidden = false;
          } else {
            litSection.hidden = true;
            gramSection.hidden = false;
            filterBar.hidden = true;
          }

          // Reset filters on tab switch
          activeFilters.theme = "";
          activeFilters.author = "";
          activeFilters.genre = "";
          for (const chip of allFilterChips) {
            if (chip instanceof HTMLElement) {
              chip.classList.toggle("active", chip.dataset.filterValue === "");
            }
          }

          applyFilters();
        });
      }

      // Multi-filter chips
      for (const chip of allFilterChips) {
        if (!(chip instanceof HTMLElement)) continue;
        chip.addEventListener("click", () => {
          const filterType = chip.dataset.filterType || "";
          const filterValue = chip.dataset.filterValue || "";

          activeFilters[filterType] = filterValue;

          // Update active state for chips of the same type
          for (const c of allFilterChips) {
            if (c instanceof HTMLElement && c.dataset.filterType === filterType) {
              c.classList.toggle("active", c.dataset.filterValue === filterValue);
            }
          }

          applyFilters();
        });
      }

      // Search
      const handleSearch = (query) => {
        searchQuery = (query || "").trim().toLocaleLowerCase("bg-BG");
        applyFilters();
      };

      document.addEventListener("search-input", (e) => {
        if (e instanceof CustomEvent) {
          handleSearch(e.detail);
        }
      });

      const searchInput = document.querySelector("[data-search-input]");
      if (searchInput instanceof HTMLInputElement) {
        searchInput.addEventListener("input", () => {
          handleSearch(searchInput.value);
        });
      }

      applyFilters();
    };

    initLanding();
    document.addEventListener("astro:page-load", initLanding);
  })();
</script>
