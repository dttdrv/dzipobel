---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

const entries: CollectionEntry<"literature">[] = (
  await getCollection("literature")
).sort(
  (left: CollectionEntry<"literature">, right: CollectionEntry<"literature">) =>
    left.data.order - right.data.order,
);

const themes: string[] = [...new Set(entries.map((entry) => entry.data.theme))];
const authors: string[] = [...new Set(entries.map((entry) => entry.data.author))].sort(
  (left, right) => left.localeCompare(right, "bg-BG"),
);

const cards = entries.map((entry, index) => ({
  href: `/literatura/${entry.id}/`,
  theme: entry.data.theme,
  author: entry.data.author,
  title: entry.data.title,
  genre: entry.data.genre,
  excerpt: entry.data.excerpt,
  motifs: entry.data.motifs.slice(0, 2),
  order: String(index + 1).padStart(2, "0"),
  searchText: `${entry.data.title} ${entry.data.author} ${entry.data.genre} ${entry.data.motifs.join(" ")} ${entry.data.conflicts.join(" ")} ${entry.data.tags.join(" ")}`.toLocaleLowerCase(
    "bg-BG",
  ),
}));
---

<BaseLayout
  title="Литература • ДЗИ библиотека"
  description="Подреден каталог с произведенията за ДЗИ по литература."
  pathname={Astro.url.pathname}
>
  <section class="band">
    <div class="hero-grid">
      <div class="hero-column reveal">
        <p class="kicker">Каталог по литература</p>
        <h1 class="detail-title">Всички произведения в една ясна редица.</h1>
        <p class="lede lede--compact">
          Търси по заглавие, автор, мотив или тема. Всяка страница е организирана така,
          че да стигнеш до смисъла на текста, а не само до кратко резюме.
        </p>
      </div>

      <div class="hero-column">
        <div class="hero-rail reveal reveal-delay-1">
          <h2 class="rail-title">В този раздел</h2>
          <ul class="rail-list">
            <li>{entries.length} произведения с теми, мотиви и конфликти на едно място.</li>
            <li>{themes.length} тематични полета за по-бързо ориентиране.</li>
            <li>Директен външен линк за четене към всяка творба.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="surface reveal" data-catalog-root>
    <div class="surface-header">
      <div class="surface-header-copy">
        <p class="kicker">Филтри</p>
        <h2 class="section-title">Открий точната творба без обикаляне.</h2>
      </div>
      <p class="result-summary" data-summary>{entries.length} произведения</p>
    </div>

    <div class="catalog-toolbar">
      <div class="toolbar-row">
        <div class="toolbar-field">
          <label class="toolbar-label" for="literature-search">
            Търси по заглавие, автор или мотив
          </label>
          <input
            id="literature-search"
            class="toolbar-input"
            type="search"
            placeholder="Например: Вапцаров, любов, избор"
            data-search
          />
        </div>

        <div class="toolbar-field toolbar-field--compact">
          <label class="toolbar-label" for="literature-theme">Тема</label>
          <select id="literature-theme" class="toolbar-select" data-theme>
            <option value="all">Всички</option>
            {themes.map((theme) => <option value={theme}>{theme}</option>)}
          </select>
        </div>

        <div class="toolbar-field toolbar-field--compact">
          <label class="toolbar-label" for="literature-author">Автор</label>
          <select id="literature-author" class="toolbar-select" data-author>
            <option value="all">Всички</option>
            {authors.map((author) => <option value={author}>{author}</option>)}
          </select>
        </div>
      </div>
    </div>

    <div class="catalog-grid stagger">
      {
        cards.map((card) => (
          <a
            href={card.href}
            class="card"
            data-card
            data-theme={card.theme}
            data-author={card.author}
            data-search-text={card.searchText}
          >
            <div class="card-shell">
              <div class="card-topline">
                <span class="pill">{card.theme}</span>
                <span class="card-index">{card.order}</span>
              </div>

              <h3 class="card-title" data-card-title>{card.title}</h3>
              <p class="card-meta">{card.author} • {card.genre}</p>
              <p class="card-copy">{card.excerpt}</p>

              <div class="card-footer">
                <div class="tag-row">
                  {card.motifs.map((motif: string) => <span class="tag">{motif}</span>)}
                </div>
                <span>Към анализа</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div class="empty-state" data-empty hidden>
      Няма съвпадения. Пробвай с по-кратък термин или избери друга тема.
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const initCatalog = () => {
      const root = document.querySelector("[data-catalog-root]");
      if (!(root instanceof HTMLElement) || root.dataset.enhanced === "true") return;

      root.dataset.enhanced = "true";

      const searchInput = root.querySelector("[data-search]");
      const themeFilter = root.querySelector("[data-theme]");
      const authorFilter = root.querySelector("[data-author]");
      const summary = root.querySelector("[data-summary]");
      const emptyState = root.querySelector("[data-empty]");
      const cards = Array.from(root.querySelectorAll("[data-card]"));

      if (!(searchInput instanceof HTMLInputElement)) return;
      if (!(themeFilter instanceof HTMLSelectElement)) return;
      if (!(authorFilter instanceof HTMLSelectElement)) return;
      if (!(summary instanceof HTMLElement)) return;
      if (!(emptyState instanceof HTMLElement)) return;

      const label = (count) => `${count} ${count === 1 ? "произведение" : "произведения"}`;

      const applyFilters = () => {
        const query = searchInput.value.trim().toLocaleLowerCase("bg-BG");
        const selectedTheme = themeFilter.value;
        const selectedAuthor = authorFilter.value;
        let visibleCount = 0;

        for (const card of cards) {
          if (!(card instanceof HTMLElement)) continue;

          const searchText = card.dataset.searchText ?? "";
          const matchesQuery = !query || searchText.includes(query);
          const matchesTheme =
            selectedTheme === "all" || card.dataset.theme === selectedTheme;
          const matchesAuthor =
            selectedAuthor === "all" || card.dataset.author === selectedAuthor;
          const isVisible = matchesQuery && matchesTheme && matchesAuthor;

          card.hidden = !isVisible;
          if (isVisible) visibleCount += 1;
        }

        summary.textContent = label(visibleCount);
        emptyState.hidden = visibleCount !== 0;
      };

      searchInput.addEventListener("input", applyFilters);
      themeFilter.addEventListener("change", applyFilters);
      authorFilter.addEventListener("change", applyFilters);
      applyFilters();
    };

    initCatalog();
    document.addEventListener("astro:page-load", initCatalog, { once: true });
  })();
</script>
