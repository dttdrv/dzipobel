---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

type LiteratureSection = {
  title: string;
  items: string[];
};

export async function getStaticPaths() {
  const entries = await getCollection("literature");
  return entries.map((entry: CollectionEntry<"literature">) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"literature"> };
const sections: LiteratureSection[] = entry.data.sections;

/* Split sections into types for different rendering */
const proseAccordions = sections.filter(
  (s) => s.title === "Композиция" || s.title === "Основни образи",
);
const deviceSection = sections.find((s) => s.title === "Изразни средства");
const otherSections = sections.filter(
  (s) =>
    s.title !== "Композиция" &&
    s.title !== "Основни образи" &&
    s.title !== "Изразни средства",
);
---

<BaseLayout
  title={`${entry.data.title} • ДЗИ библиотека`}
  description={entry.data.excerpt}
  hideNav={true}
>
  <!-- HERO -->
  <section class="lit-hero">
    <a href="/" class="back-link" aria-label="Обратно">←</a>
    <div class="lit-hero-meta">
      <span class="lit-hero-badge">{entry.data.genre}</span>
      <span class="lit-hero-badge">{entry.data.theme}</span>
    </div>
    <h1 class="lit-hero-title">{entry.data.title}</h1>
    <p class="lit-hero-author">{entry.data.author}</p>
    <a
      class="btn btn-primary"
      href={entry.data.readUrl}
      target="_blank"
      rel="noreferrer"
    >
      Прочети в {entry.data.readSource} ↗
    </a>
  </section>

  <div class="lit-body">

    <!-- EXCERPT — always visible -->
    <p class="lit-excerpt">{entry.data.excerpt}</p>

    <!-- QUICK-SCAN: Motifs + Conflicts as pills -->
    <div class="lit-scan">
      <div class="lit-scan-group">
        <h3 class="lit-scan-label">Мотиви</h3>
        <div class="lit-pills">
          {entry.data.motifs.map((m: string) => (
            <span class="lit-pill lit-pill--motif">{m}</span>
          ))}
        </div>
      </div>

      <div class="lit-scan-group">
        <h3 class="lit-scan-label">Конфликти</h3>
        <div class="lit-pills">
          {entry.data.conflicts.map((c: string) => (
            <span class="lit-pill lit-pill--conflict">{c}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- PROSE SECTIONS — accordions for long text -->
    <div class="lit-prose-section">
      <details class="acc" data-accordion>
        <summary class="acc-head">
          <span class="acc-title">За автора</span>
          <span class="acc-chevron" aria-hidden="true"></span>
        </summary>
        <div class="acc-body">
          <p class="acc-text">{entry.data.aboutAuthor}</p>
        </div>
      </details>

      <details class="acc" data-accordion>
        <summary class="acc-head">
          <span class="acc-title">За произведението</span>
          <span class="acc-chevron" aria-hidden="true"></span>
        </summary>
        <div class="acc-body">
          <p class="acc-text">{entry.data.aboutWork}</p>
        </div>
      </details>

      {proseAccordions.map((section) => (
        <details class="acc" data-accordion>
          <summary class="acc-head">
            <span class="acc-title">{section.title}</span>
            <span class="acc-chevron" aria-hidden="true"></span>
          </summary>
          <div class="acc-body">
            <ul>
              {section.items.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </details>
      ))}
    </div>

    <!-- LITERARY DEVICES — always visible, callout boxes -->
    {deviceSection && (
      <div class="lit-devices">
        <h3 class="lit-devices-title">Изразни средства</h3>
        <div class="lit-devices-grid">
          {deviceSection.items.map((item: string) => {
            const dashIdx = item.indexOf(" \u2013 ");
            const name = dashIdx > -1 ? item.slice(0, dashIdx) : item;
            const desc = dashIdx > -1 ? item.slice(dashIdx + 3) : "";
            return (
              <div class="lit-device">
                <span class="lit-device-name">{name}</span>
                {desc && <span class="lit-device-desc">{desc}</span>}
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- OTHER SECTIONS -->
    {otherSections.length > 0 && otherSections.map((section) => (
      <details class="acc" data-accordion>
        <summary class="acc-head">
          <span class="acc-title">{section.title}</span>
          <span class="acc-chevron" aria-hidden="true"></span>
        </summary>
        <div class="acc-body">
          {section.items.length > 1 ? (
            <ul>
              {section.items.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          ) : (
            <p class="acc-text">{section.items[0]}</p>
          )}
        </div>
      </details>
    ))}

    <!-- MESSAGE — highlight box -->
    <div class="lit-message">
      <h3 class="lit-message-label">Послание</h3>
      <p class="lit-message-text">{entry.data.message}</p>
    </div>

  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const initAccordion = () => {
      const details = document.querySelectorAll("[data-accordion]");
      if (!details.length) return;
      const first = details[0];
      if (first instanceof HTMLElement && first.dataset.enhanced === "true") return;
      if (first instanceof HTMLElement) first.dataset.enhanced = "true";
    };

    initAccordion();
    document.addEventListener("astro:page-load", initAccordion);
  })();
</script>
