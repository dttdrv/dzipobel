---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

type LiteratureSection = {
  title: string;
  items: string[];
};

export async function getStaticPaths() {
  const entries = await getCollection("literature");
  return entries.map((entry: CollectionEntry<"literature">) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

export const prerender = true;

const { entry } = Astro.props as { entry: CollectionEntry<"literature"> };
const sections: LiteratureSection[] = entry.data.sections;

const compositionSection = sections.find((s) => s.title === "Композиция");
const charactersSection = sections.find((s) => s.title === "Основни образи");
const deviceSection = sections.find((s) => s.title === "Изразни средства");
const otherSections = sections.filter(
  (s) =>
    s.title !== "Композиция" &&
    s.title !== "Основни образи" &&
    s.title !== "Изразни средства",
);
---

<BaseLayout
  title={`${entry.data.title} • ДЗИ библиотека`}
  description={entry.data.excerpt}
  isDetail={true}
  detailTitle={entry.data.title}
  detailSub={entry.data.author}
  readUrl={entry.data.readUrl}
>

  <!-- HERO — left-aligned, above main content -->
  <section class="lit-hero page-reveal" id="lit-hero">
    <div class="lit-hero-badges">
      <span class="lit-hero-badge">{entry.data.genre}</span>
      <span class="lit-hero-sep">·</span>
      <span class="lit-hero-badge">{entry.data.theme}</span>
    </div>
    <h1 class="lit-hero-title" data-scroll-sentinel data-morph-source transition:name={`title-${entry.id}`}>{entry.data.title}</h1>
    <span class="lit-hero-author">{entry.data.author}</span>
  </section>

  <!-- TWO-COLUMN LAYOUT (main left, sidebar right) -->
  <div class="lit-page">
    <!-- MAIN CONTENT (left, in focus) -->
    <main class="lit-main">
      <p class="lit-main-excerpt page-reveal">{entry.data.excerpt}</p>

      <section class="lit-section page-reveal">
        <h2 class="lit-section-title">За автора</h2>
        <p class="lit-section-text">{entry.data.aboutAuthor}</p>
      </section>

      <section class="lit-section page-reveal">
        <h2 class="lit-section-title">За произведението</h2>
        <p class="lit-section-text">{entry.data.aboutWork}</p>
      </section>

      {compositionSection && (
        <section class="lit-section page-reveal">
          <h2 class="lit-section-title">Композиция</h2>
          <ul class="lit-section-list">
            {compositionSection.items.map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )}

      {/* Mobile-only: Motifs + Conflicts below Composition */}
      {entry.data.motifs && entry.data.motifs.length > 0 && (
        <section class="lit-section lit-section--mobile-only page-reveal">
          <h2 class="lit-section-title">Мотиви</h2>
          <ul class="lit-section-list">
            {entry.data.motifs.map((m: string) => (
              <li>{m}</li>
            ))}
          </ul>
        </section>
      )}

      {entry.data.conflicts && entry.data.conflicts.length > 0 && (
        <section class="lit-section lit-section--mobile-only page-reveal">
          <h2 class="lit-section-title">Конфликти</h2>
          <ul class="lit-section-list">
            {entry.data.conflicts.map((c: string) => (
              <li>{c}</li>
            ))}
          </ul>
        </section>
      )}

      {charactersSection && (
        <section class="lit-section page-reveal">
          <h2 class="lit-section-title">Основни образи</h2>
          <ul class="lit-section-list">
            {charactersSection.items.map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      )}

      {otherSections.map((section) => (
        <section class="lit-section page-reveal">
          <h2 class="lit-section-title">{section.title}</h2>
          {section.items.length > 1 ? (
            <ul class="lit-section-list">
              {section.items.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          ) : (
            <p class="lit-section-text">{section.items[0]}</p>
          )}
        </section>
      ))}

      {/* Key quotes */}
      {entry.data.keyQuotes && entry.data.keyQuotes.length > 0 && (
        <section class="lit-section page-reveal">
          <h2 class="lit-section-title">Ключови цитати</h2>
          <div class="lit-quotes">
            {entry.data.keyQuotes.map((q: { text: string; analysis: string; theme?: string }) => (
              <blockquote class="lit-quote">
                <p class="lit-quote-text">{q.text}</p>
                <p class="lit-quote-analysis">{q.analysis}</p>
                {q.theme && <span class="lit-quote-theme">{q.theme}</span>}
              </blockquote>
            ))}
          </div>
        </section>
      )}

      {/* Mobile-only: Devices below Quotes */}
      {deviceSection && (
        <section class="lit-section lit-section--mobile-only page-reveal">
          <h2 class="lit-section-title">Изразни средства</h2>
          <ul class="lit-section-list lit-section-list--devices">
            {deviceSection.items.map((item: string) => {
              const dashIdx = item.indexOf(" \u2013 ");
              const name = dashIdx > -1 ? item.slice(0, dashIdx) : item;
              const desc = dashIdx > -1 ? item.slice(dashIdx + 3) : "";
              return (
                <li>
                  <strong>{name}</strong>
                  {desc && <span class="lit-device-desc"> — {desc}</span>}
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {/* Послание — standalone closing passage, not boxed */}
      <div class="lit-message page-reveal">
        <span class="lit-message-label">Послание</span>
        <p class="lit-message-text">{entry.data.message}</p>
      </div>
    </main>

    <!-- SIDEBAR (right) — full metadata on desktop, only Жанр + Тема on mobile -->
    <aside class="lit-sidebar page-reveal">
      <div class="lit-sidebar-block">
        <h3 class="lit-sidebar-label">Жанр</h3>
        <p class="lit-sidebar-value">{entry.data.genre}</p>
      </div>

      <div class="lit-sidebar-block">
        <h3 class="lit-sidebar-label">Тема</h3>
        <p class="lit-sidebar-value">{entry.data.theme}</p>
      </div>

      <div class="lit-sidebar-block lit-sidebar-block--detail">
        <h3 class="lit-sidebar-label">Мотиви</h3>
        <ul class="lit-sidebar-list">
          {entry.data.motifs.map((m: string) => <li>{m}</li>)}
        </ul>
      </div>

      <div class="lit-sidebar-block lit-sidebar-block--detail">
        <h3 class="lit-sidebar-label">Конфликти</h3>
        <ul class="lit-sidebar-list">
          {entry.data.conflicts.map((c: string) => <li>{c}</li>)}
        </ul>
      </div>

      {deviceSection && (
        <div class="lit-sidebar-block lit-sidebar-block--detail">
          <h3 class="lit-sidebar-label">Изразни средства</h3>
          <ul class="lit-sidebar-list">
            {deviceSection.items.map((item: string) => {
              const dashIdx = item.indexOf(" \u2013 ");
              const name = dashIdx > -1 ? item.slice(0, dashIdx) : item;
              const desc = dashIdx > -1 ? item.slice(dashIdx + 3) : "";
              return (
                <li>
                  <strong>{name}</strong>
                  {desc && <span class="lit-sidebar-subdesc"> {desc}</span>}
                </li>
              );
            })}
          </ul>
        </div>
      )}
    </aside>
  </div>
</BaseLayout>


