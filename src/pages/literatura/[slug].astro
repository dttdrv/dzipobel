---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

type LiteratureSection = {
  title: string;
  items: string[];
};

export async function getStaticPaths() {
  const entries = await getCollection("literature");
  return entries.map((entry: CollectionEntry<"literature">) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

export const prerender = true;

const { entry } = Astro.props as { entry: CollectionEntry<"literature"> };
const sections: LiteratureSection[] = entry.data.sections;

const proseAccordions = sections.filter(
  (s) => s.title === "Композиция" || s.title === "Основни образи",
);
const deviceSection = sections.find((s) => s.title === "Изразни средства");
const otherSections = sections.filter(
  (s) =>
    s.title !== "Композиция" &&
    s.title !== "Основни образи" &&
    s.title !== "Изразни средства",
);
---

<BaseLayout
  title={`${entry.data.title} • ДЗИ библиотека`}
  description={entry.data.excerpt}
  hideNav={true}
>
  <!-- FULL-WIDTH HERO BAR -->
  <div class="lit-topbar">
    <a href="/" class="lit-topbar-back">← Назад</a>
    <div class="lit-topbar-center">
      <span class="lit-topbar-title">{entry.data.title}</span>
      <span class="lit-topbar-author">{entry.data.author}</span>
    </div>
    <a
      class="lit-topbar-cta"
      href={entry.data.readUrl}
      target="_blank"
      rel="noreferrer"
    >
      Прочети ↗
    </a>
  </div>

  <!-- TWO-COLUMN LAYOUT -->
  <div class="lit-page">

    <!-- MAIN CONTENT (first in DOM for reading order) -->
    <main class="lit-main">
      <p class="lit-main-excerpt">{entry.data.excerpt}</p>

      <section class="lit-section">
        <h2 class="lit-section-title">За автора</h2>
        <p class="lit-section-text">{entry.data.aboutAuthor}</p>
      </section>

      <section class="lit-section">
        <h2 class="lit-section-title">За произведението</h2>
        <p class="lit-section-text">{entry.data.aboutWork}</p>
      </section>

      {proseAccordions.map((section) => (
        <section class="lit-section">
          <h2 class="lit-section-title">{section.title}</h2>
          <ul class="lit-section-list">
            {section.items.map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))}

      {otherSections.map((section) => (
        <section class="lit-section">
          <h2 class="lit-section-title">{section.title}</h2>
          {section.items.length > 1 ? (
            <ul class="lit-section-list">
              {section.items.map((item: string) => (
                <li>{item}</li>
              ))}
            </ul>
          ) : (
            <p class="lit-section-text">{section.items[0]}</p>
          )}
        </section>
      ))}

      <div class="lit-message">
        <h3 class="lit-message-label">Послание</h3>
        <p class="lit-message-text">{entry.data.message}</p>
      </div>
    </main>

    <!-- SIDEBAR: quick-scan info (right side) -->
    <aside class="lit-sidebar">
      <div class="lit-sidebar-block">
        <h3 class="lit-sidebar-label">Жанр</h3>
        <p class="lit-sidebar-value">{entry.data.genre}</p>
      </div>

      <div class="lit-sidebar-block">
        <h3 class="lit-sidebar-label">Тема</h3>
        <p class="lit-sidebar-value">{entry.data.theme}</p>
      </div>

      <div class="lit-sidebar-block">
        <h3 class="lit-sidebar-label">Мотиви</h3>
        <ul class="lit-sidebar-list lit-sidebar-list--motif">
          {entry.data.motifs.map((m: string) => <li>{m}</li>)}
        </ul>
      </div>

      <div class="lit-sidebar-block">
        <h3 class="lit-sidebar-label">Конфликти</h3>
        <ul class="lit-sidebar-list lit-sidebar-list--conflict">
          {entry.data.conflicts.map((c: string) => <li>{c}</li>)}
        </ul>
      </div>

      {deviceSection && (
        <div class="lit-sidebar-block">
          <h3 class="lit-sidebar-label">Изразни средства</h3>
          <div class="lit-device-stack">
            {deviceSection.items.map((item: string) => {
              const dashIdx = item.indexOf(" \u2013 ");
              const name = dashIdx > -1 ? item.slice(0, dashIdx) : item;
              const desc = dashIdx > -1 ? item.slice(dashIdx + 3) : "";
              return (
                <div class="lit-device-card">
                  <span class="lit-device-card-name">{name}</span>
                  {desc && <span class="lit-device-card-desc">{desc}</span>}
                </div>
              );
            })}
          </div>
        </div>
      )}
    </aside>

  </div>
</BaseLayout>
