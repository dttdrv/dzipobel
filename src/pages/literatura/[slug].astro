---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

type LiteratureSection = {
  title: string;
  items: string[];
};

export async function getStaticPaths() {
  const entries = await getCollection("literature");
  return entries.map((entry: CollectionEntry<"literature">) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"literature"> };
const sections: LiteratureSection[] = entry.data.sections;
---

<BaseLayout
  title={`${entry.data.title} • ДЗИ библиотека`}
  description={entry.data.excerpt}
>
  <section class="detail-header">
    <a href="/" class="back-link" aria-label="Обратно">←</a>
    <span class="detail-kicker">{entry.data.genre} · {entry.data.theme}</span>
    <h1 class="detail-title">{entry.data.title}</h1>
    <span class="detail-author">{entry.data.author}</span>
  </section>

  <div class="detail-cta">
    <a
      class="btn btn-primary"
      href={entry.data.readUrl}
      target="_blank"
      rel="noreferrer"
    >
      Прочети в {entry.data.readSource} ↗
    </a>
  </div>

  <div class="detail-content">
    <div class="acc-toolbar">
      <button class="acc-toggle-all" data-expand-all>Отвори всички</button>
    </div>

    <details class="acc" data-accordion>
      <summary class="acc-head">
        <span class="acc-title">За автора</span>
        <span class="acc-chevron" aria-hidden="true"></span>
      </summary>
      <div class="acc-body">
        <p class="acc-text">{entry.data.aboutAuthor}</p>
      </div>
    </details>

    <details class="acc" data-accordion>
      <summary class="acc-head">
        <span class="acc-title">За произведението</span>
        <span class="acc-chevron" aria-hidden="true"></span>
      </summary>
      <div class="acc-body">
        <p class="acc-text">{entry.data.aboutWork}</p>
      </div>
    </details>

    <details class="acc" data-accordion>
      <summary class="acc-head">
        <span class="acc-title">Мотиви</span>
        <span class="acc-chevron" aria-hidden="true"></span>
      </summary>
      <div class="acc-body">
        <ul>
          {entry.data.motifs.map((m: string) => <li>{m}</li>)}
        </ul>
      </div>
    </details>

    <details class="acc" data-accordion>
      <summary class="acc-head">
        <span class="acc-title">Конфликти</span>
        <span class="acc-chevron" aria-hidden="true"></span>
      </summary>
      <div class="acc-body">
        <ul>
          {entry.data.conflicts.map((c: string) => <li>{c}</li>)}
        </ul>
      </div>
    </details>

    {
      sections.map((section) => (
        <details class="acc" data-accordion>
          <summary class="acc-head">
            <span class="acc-title">{section.title}</span>
            <span class="acc-chevron" aria-hidden="true"></span>
          </summary>
          <div class="acc-body">
            {section.items.length > 1 ? (
              <ul>
                {section.items.map((item: string) => (
                  <li>{item}</li>
                ))}
              </ul>
            ) : (
              <p class="acc-text">{section.items[0]}</p>
            )}
          </div>
        </details>
      ))
    }

    <details class="acc" data-accordion>
      <summary class="acc-head">
        <span class="acc-title">Послание</span>
        <span class="acc-chevron" aria-hidden="true"></span>
      </summary>
      <div class="acc-body">
        <p class="acc-text">{entry.data.message}</p>
      </div>
    </details>
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const initAccordion = () => {
      const toggleBtn = document.querySelector("[data-expand-all]");
      if (!(toggleBtn instanceof HTMLElement) || toggleBtn.dataset.enhanced === "true") return;
      toggleBtn.dataset.enhanced = "true";

      const allDetails = Array.from(document.querySelectorAll("[data-accordion]"));
      let allOpen = false;

      toggleBtn.addEventListener("click", () => {
        allOpen = !allOpen;
        for (const d of allDetails) {
          if (d instanceof HTMLDetailsElement) {
            d.open = allOpen;
          }
        }
        toggleBtn.textContent = allOpen ? "Затвори всички" : "Отвори всички";
      });
    };

    initAccordion();
    document.addEventListener("astro:page-load", initAccordion);
  })();
</script>
