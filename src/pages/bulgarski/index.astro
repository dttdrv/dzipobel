---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

const entries: CollectionEntry<"grammar">[] = (
  await getCollection("grammar")
).sort(
  (
    left: CollectionEntry<"grammar">,
    right: CollectionEntry<"grammar">,
  ) => left.data.order - right.data.order,
);

const modules: string[] = [...new Set(entries.map((entry) => entry.data.module))];

const cards = entries.map((entry, index) => ({
  href: `/bulgarski/${entry.id}/`,
  module: entry.data.module,
  title: entry.data.title,
  excerpt: entry.data.excerpt,
  tags: entry.data.tags.slice(0, 2),
  order: String(index + 1).padStart(2, "0"),
  searchText: `${entry.data.title} ${entry.data.module} ${entry.data.sectionTitle} ${entry.data.excerpt} ${entry.data.tags.join(" ")} ${entry.data.bullets.join(" ")}`.toLocaleLowerCase(
    "bg-BG",
  ),
}));

const formatGrammarCount = (count: number) =>
  count === 1 ? "1 модул" : `${count} модула`;
---

<BaseLayout
  title="Български език • ДЗИ библиотека"
  description="Каталог с граматичните модули за ДЗИ по български език."
  pathname={Astro.url.pathname}
>
  <section class="band">
    <div class="hero-grid">
      <div class="hero-column reveal">
        <p class="kicker">Каталог по български език</p>
        <h1 class="detail-title">Правилата са подредени така, че да не те спъват.</h1>
        <p class="lede lede--compact">
          Морфология, синтаксис и правопис в по-спокойна и по-четима структура,
          вместо в безкраен списък от правила.
        </p>
      </div>

      <div class="hero-column">
        <div class="hero-rail reveal reveal-delay-1">
          <h2 class="rail-title">Как да ползваш модула</h2>
          <ul class="rail-list">
            <li>Търси по термин или правило, когато знаеш какво точно търсиш.</li>
            <li>Преглеждай целите модули, когато искаш да повториш по раздел.</li>
            <li>Отваряй detail страниците за по-плътна, но подредена версия на материала.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="surface surface--cool reveal" data-grammar-root>
    <div class="surface-header">
      <div class="surface-header-copy">
        <p class="kicker">Филтри</p>
        <h2 class="section-title">Намери точния модул или правило.</h2>
      </div>
    </div>

    <div class="catalog-toolbar">
      <div class="toolbar-row">
        <div class="toolbar-field">
          <label class="toolbar-label" for="grammar-search">
            Търси по правило, термин или ключова дума
          </label>
          <input
            id="grammar-search"
            class="toolbar-input"
            type="search"
            placeholder="Например: запетая, глагол, главна буква"
            data-search
          />
        </div>

        <div class="toolbar-field toolbar-field--compact">
          <label class="toolbar-label" for="grammar-module">Модул</label>
          <select id="grammar-module" class="toolbar-select" data-module>
            <option value="all">Всички</option>
            {modules.map((module) => <option value={module}>{module}</option>)}
          </select>
        </div>
      </div>
    </div>

    <p class="result-summary" data-summary>{formatGrammarCount(entries.length)}</p>

    <div class="catalog-grid stagger">
      {
        cards.map((card) => (
          <a
            href={card.href}
            class="card"
            data-card
            data-module={card.module}
            data-search-text={card.searchText}
          >
            <div class="card-shell">
              <div class="card-topline">
                <span class="pill pill--secondary">{card.module}</span>
                <span class="card-index">{card.order}</span>
              </div>

              <h3 class="card-title" data-card-title>{card.title}</h3>
              <p class="card-copy">{card.excerpt}</p>

              <div class="tag-row">
                {card.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>

              <div class="card-footer">
                <span>Отвори модула</span>
                <span>→</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div class="empty-state" data-empty hidden>
      Няма съвпадения. Пробвай с друг термин или отвори модулите поотделно.
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-grammar-root]");
    if (!root) return;

    const searchInput = root.querySelector("[data-search]");
    const moduleFilter = root.querySelector("[data-module]");
    const summary = root.querySelector("[data-summary]");
    const emptyState = root.querySelector("[data-empty]");
    const cards = Array.from(root.querySelectorAll("[data-card]"));

    if (!(searchInput instanceof HTMLInputElement)) return;
    if (!(moduleFilter instanceof HTMLSelectElement)) return;
    if (!(summary instanceof HTMLElement)) return;
    if (!(emptyState instanceof HTMLElement)) return;

    const formatCount = (count) => (count === 1 ? "1 модул" : `${count} модула`);

    const applyFilters = () => {
      const query = searchInput.value.trim().toLocaleLowerCase("bg-BG");
      const selectedModule = moduleFilter.value;
      let visibleCount = 0;

      for (const card of cards) {
        if (!(card instanceof HTMLElement)) continue;

        const searchText = card.dataset.searchText ?? "";
        const matchesQuery = !query || searchText.includes(query);
        const matchesModule =
          selectedModule === "all" || card.dataset.module === selectedModule;
        const isVisible = matchesQuery && matchesModule;

        card.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      }

      summary.textContent = formatCount(visibleCount);
      emptyState.hidden = visibleCount !== 0;
    };

    searchInput.addEventListener("input", applyFilters);
    moduleFilter.addEventListener("change", applyFilters);
  })();
</script>
