---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

type CommonMistake = {
  wrong: string;
  right: string;
  explanation: string;
};

type QuizQuestion = {
  question: string;
  options: string[];
  correct: number;
  explanation: string;
};

type GrammarSection = {
  title: string;
  items: string[];
  verificationTrick?: string;
  commonMistakes?: CommonMistake[];
  quiz?: QuizQuestion[];
};

export async function getStaticPaths() {
  const entries = await getCollection("grammar");
  return entries.map((entry: CollectionEntry<"grammar">) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"grammar"> };
const sections = entry.data.sections as GrammarSection[];

function classifyItem(text: string): string {
  if (/^═══/.test(text)) return "is-separator";
  if (/^(Пример[иа]?:|ПРИМЕР|Напр\.)/.test(text)) return "is-example";
  if (/^(ВАЖНО|ПРАВИЛО|ЗАПОМНИ|Правило|Внимание|Тук е важно|Забележете|Любопитно|Опитай):/i.test(text)) return "is-rule";
  return "";
}

function isSeparatorSection(title: string): boolean {
  return /^═══/.test(title);
}

const contentSections = sections.filter((s) => !isSeparatorSection(s.title));
---

<BaseLayout
  title={`${entry.data.title} • ДЗИ библиотека`}
  description={entry.data.excerpt}
  hideNav={true}
>
  <!-- TOP BAR -->
  <div class="gram-topbar">
    <a href="/" class="gram-topbar-back">← Назад</a>
    <button class="gram-toc-toggle" id="toc-toggle" aria-label="Съдържание">☰</button>
    <span class="gram-topbar-title">{entry.data.title}</span>
    <span class="gram-topbar-count">{contentSections.length} раздела</span>
  </div>

  <!-- Mobile TOC overlay -->
  <div class="gram-toc-overlay" id="toc-overlay"></div>

  <div class="gram-page">
    <!-- SIDEBAR: table of contents -->
    <aside class="gram-toc" id="gram-toc">
      <h3 class="gram-toc-label">{entry.data.module}</h3>
      <nav class="gram-toc-nav">
        {contentSections.map((section, idx) => (
          <a href={`#section-${idx}`} class="gram-toc-link">
            <span class="gram-toc-link-text">{section.title}</span>
            {(section.quiz && section.quiz.length > 0) && <span class="gram-toc-badge" title="Има тест">?</span>}
          </a>
        ))}
      </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="gram-main">
      <div class="gram-main-header">
        <h1 class="gram-main-title" transition:name={`title-${entry.id}`}>{entry.data.title}</h1>
        <p class="gram-main-excerpt">{entry.data.excerpt}</p>
      </div>

      {
        sections.map((section) => {
          const isSep = isSeparatorSection(section.title);

          if (isSep) {
            return (
              <div class="acc-divider" role="separator">
                <span>{section.title.replace(/═/g, "").trim()}</span>
              </div>
            );
          }

          const sectionIdx = contentSections.indexOf(section);

          return (
            <section class="gram-section" id={`section-${sectionIdx}`}>
              <h2 class="gram-section-title">{section.title}</h2>

              {/* Verification trick */}
              {section.verificationTrick && (
                <div class="trick-box">
                  <span class="trick-label">Бърза проверка</span>
                  <p class="trick-text">{section.verificationTrick}</p>
                </div>
              )}

              {/* Main items */}
              <ul class="gram-section-list">
                {section.items.map((item: string) => {
                  const cls = classifyItem(item);
                  return <li class={cls || undefined}>{item}</li>;
                })}
              </ul>

              {/* Common mistakes */}
              {section.commonMistakes && section.commonMistakes.length > 0 && (
                <div class="mistakes-block">
                  <span class="mistakes-label">Чести грешки</span>
                  <div class="mistakes-list">
                    {section.commonMistakes.map((m) => (
                      <div class="mistake-pair">
                        <span class="mistake-wrong">{m.wrong}</span>
                        <span class="mistake-right">{m.right}</span>
                        <span class="mistake-why">{m.explanation}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Quiz */}
              {section.quiz && section.quiz.length > 0 && (
                <div class="quiz-block" data-quiz data-quiz-questions={JSON.stringify(section.quiz)}>
                  <span class="quiz-label">Провери се</span>
                </div>
              )}
            </section>
          );
        })
      }
    </main>
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const initQuizzes = () => {
      const quizBlocks = document.querySelectorAll("[data-quiz]");
      for (const block of quizBlocks) {
        if (!(block instanceof HTMLElement) || block.dataset.enhanced === "true") continue;
        block.dataset.enhanced = "true";

        const questions = JSON.parse(block.dataset.quizQuestions || "[]");
        if (questions.length === 0) continue;

        let currentQ = 0;

        function renderQuestion() {
          const q = questions[currentQ];
          block.innerHTML =
            '<span class="quiz-label">Провери се</span>' +
            '<div class="quiz-question">' + q.question + '</div>' +
            '<div class="quiz-options">' +
            q.options.map(function(opt, i) {
              return '<button class="quiz-opt" data-idx="' + i + '">' + opt + '</button>';
            }).join("") +
            '</div>' +
            '<div class="quiz-feedback" hidden></div>' +
            (questions.length > 1 ? '<div class="quiz-counter">' + (currentQ + 1) + ' / ' + questions.length + '</div>' : '');

          const opts = block.querySelectorAll(".quiz-opt");
          const feedback = block.querySelector(".quiz-feedback");

          for (const opt of opts) {
            opt.addEventListener("click", function() {
              if (!(opt instanceof HTMLElement) || !(feedback instanceof HTMLElement)) return;
              const idx = parseInt(opt.dataset.idx || "0", 10);
              const isCorrect = idx === q.correct;

              for (const o of opts) {
                if (o instanceof HTMLElement) {
                  o.classList.add("quiz-opt--disabled");
                  if (parseInt(o.dataset.idx || "0", 10) === q.correct) {
                    o.classList.add("quiz-opt--correct");
                  }
                  if (parseInt(o.dataset.idx || "0", 10) === idx && !isCorrect) {
                    o.classList.add("quiz-opt--wrong");
                  }
                }
              }

              feedback.hidden = false;
              feedback.className = "quiz-feedback " + (isCorrect ? "quiz-feedback--correct" : "quiz-feedback--wrong");
              feedback.textContent = isCorrect ? "Правилно! " + q.explanation : "Грешка. " + q.explanation;

              if (currentQ < questions.length - 1) {
                const nextBtn = document.createElement("button");
                nextBtn.className = "quiz-next";
                nextBtn.textContent = "Следващ въпрос →";
                nextBtn.addEventListener("click", function() {
                  currentQ++;
                  renderQuestion();
                });
                feedback.appendChild(nextBtn);
              }
            });
          }
        }

        renderQuestion();
      }
    };

    /* Highlight active TOC link on scroll */
    const initTocHighlight = () => {
      const links = document.querySelectorAll(".gram-toc-link");
      const sectionEls = document.querySelectorAll(".gram-section[id]");
      if (!links.length || !sectionEls.length) return;

      const obs = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              for (const link of links) {
                if (link instanceof HTMLElement) {
                  link.classList.toggle("gram-toc-link--active", link.getAttribute("href") === "#" + id);
                }
              }
            }
          }
        },
        { threshold: 0.1, rootMargin: "-80px 0px -60% 0px" },
      );
      for (const el of sectionEls) obs.observe(el);
    };

    /* Mobile TOC toggle */
    const initTocToggle = () => {
      const toggle = document.getElementById("toc-toggle");
      const toc = document.getElementById("gram-toc");
      const overlay = document.getElementById("toc-overlay");
      if (!toggle || !toc || !overlay) return;

      const open = () => { toc.dataset.open = "true"; overlay.dataset.open = "true"; };
      const close = () => { toc.dataset.open = "false"; overlay.dataset.open = "false"; };

      toggle.addEventListener("click", open);
      overlay.addEventListener("click", close);

      // Close on TOC link click (mobile)
      const links = toc.querySelectorAll(".gram-toc-link");
      for (const link of links) {
        link.addEventListener("click", close);
      }
    };

    const initAll = () => {
      initQuizzes();
      initTocHighlight();
      initTocToggle();
    };

    initAll();
    document.addEventListener("astro:page-load", initAll);
  })();
</script>
