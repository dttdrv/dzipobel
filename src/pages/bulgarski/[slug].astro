---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

type CommonMistake = {
  wrong: string;
  right: string;
  explanation: string;
};

type QuizQuestion = {
  question: string;
  options: string[];
  correct: number;
  explanation: string;
};

type GrammarSection = {
  title: string;
  items: string[];
  verificationTrick?: string;
  commonMistakes?: CommonMistake[];
  quiz?: QuizQuestion[];
};

export async function getStaticPaths() {
  const entries = await getCollection("grammar");
  return entries.map((entry: CollectionEntry<"grammar">) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"grammar"> };
const allGrammar = (await getCollection("grammar")).sort(
  (a: CollectionEntry<"grammar">, b: CollectionEntry<"grammar">) => a.data.order - b.data.order,
);
const sections = entry.data.sections as GrammarSection[];

function classifyItem(text: string): string {
  if (/^═══/.test(text)) return "is-separator";
  if (/^(Пример[иа]?:|ПРИМЕР|Напр\.)/.test(text)) return "is-example";
  if (/^(ВАЖНО|ПРАВИЛО|ЗАПОМНИ|Правило|Внимание|Тук е важно|Забележете|Любопитно|Опитай):/i.test(text)) return "is-rule";
  return "";
}

function isSeparatorSection(title: string): boolean {
  return /^═══/.test(title);
}

const contentSections = sections.filter((s) => !isSeparatorSection(s.title));
---

<BaseLayout
  title={`${entry.data.title} • ДЗИ библиотека`}
  description={entry.data.excerpt}
  isDetail={true}
  detailTitle={entry.data.title}
  backUrl="/"
>
  <!-- Edge-hover handle (bulge) — opens TOC -->
  <button class="gram-toc-handle" id="toc-handle" aria-label="Покажи съдържание" aria-controls="gram-toc">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="9 6 15 12 9 18"></polyline>
    </svg>
  </button>
  <!-- Invisible hover edge -->
  <div class="gram-toc-hover-edge" id="toc-hover-edge" aria-hidden="true"></div>

  <!-- Backdrop overlay -->
  <div class="gram-toc-overlay" id="toc-overlay"></div>

  <div class="gram-page">
    <!-- SIDEBAR: table of contents & categories -->
    <aside class="gram-toc" id="gram-toc">
      <h3 class="gram-toc-label">В тази тема</h3>
      <nav class="gram-toc-nav">
        {contentSections.map((section, idx) => (
          <div class="gram-toc-row">
            <a href={`#section-${idx}`} class="gram-toc-link">
              <span class="gram-toc-link-text">{section.title}</span>
            </a>
            {section.quiz && section.quiz.length > 0 && (
              <a href={`#quiz-${idx}`} class="gram-toc-test" title="Тест за раздела">Тест</a>
            )}
          </div>
        ))}
      </nav>

      <div class="gram-toc-divider"></div>

      <h3 class="gram-toc-label">Всички теми</h3>
      <nav class="gram-toc-nav">
        {allGrammar.map((g) => (
          <a href={`/bulgarski/${g.id}/`} class={`gram-toc-link ${g.id === entry.id ? "gram-toc-link--active" : ""}`}>
            <span class="gram-toc-link-text">{g.data.title}</span>
          </a>
        ))}
      </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="gram-main">
      <div class="gram-main-header page-reveal">
        <h1 class="gram-main-title" data-scroll-sentinel data-morph-source transition:name={`title-${entry.id}`}>{entry.data.title}</h1>
        <p class="gram-main-excerpt">{entry.data.excerpt}</p>
      </div>

      {
        sections.map((section) => {
          const isSep = isSeparatorSection(section.title);

          if (isSep) {
            return (
              <div class="acc-divider page-reveal" role="separator">
                <span>{section.title.replace(/═/g, "").trim()}</span>
              </div>
            );
          }

          const sectionIdx = contentSections.indexOf(section);

          return (
            <section class="gram-section page-reveal" id={`section-${sectionIdx}`}>
              <h2 class="gram-section-title">{section.title}</h2>

              {/* Verification trick */}
              {section.verificationTrick && (
                <div class="trick-box">
                  <span class="trick-label">Бърза проверка</span>
                  <p class="trick-text">{section.verificationTrick}</p>
                </div>
              )}

              {/* Main items */}
              <ul class="gram-section-list">
                {section.items.map((item: string) => {
                  const cls = classifyItem(item);
                  return <li class={cls || undefined}>{item}</li>;
                })}
              </ul>

              {/* Common mistakes */}
              {section.commonMistakes && section.commonMistakes.length > 0 && (
                <div class="mistakes-block">
                  <span class="mistakes-label">Чести грешки</span>
                  <div class="mistakes-list">
                    {section.commonMistakes.map((m: CommonMistake) => (
                      <div class="mistake-pair">
                        <span class="mistake-wrong">{m.wrong}</span>
                        <span class="mistake-right">{m.right}</span>
                        <span class="mistake-why">{m.explanation}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Per-section quiz — prominent */}
              {section.quiz && section.quiz.length > 0 && (
                <aside
                  class="gram-quiz-card"
                  id={`quiz-${sectionIdx}`}
                  data-section-quiz={JSON.stringify(section.quiz)}
                  aria-labelledby={`quiz-${sectionIdx}-title`}
                >
                  <div class="gram-quiz-card-head">
                    <span class="gram-quiz-card-kicker">Тест</span>
                    <h3 id={`quiz-${sectionIdx}-title`} class="gram-quiz-card-title">Провери знанията си</h3>
                    <p class="gram-quiz-card-sub">{section.quiz.length} {section.quiz.length === 1 ? "въпрос" : "въпроса"} от „{section.title}“</p>
                  </div>
                  <div class="gram-quiz-progress" aria-hidden="true"><div class="gram-quiz-progress-bar" data-quiz-progress></div></div>
                  <div class="gram-quiz-stage" data-quiz-stage aria-live="polite"></div>
                </aside>
              )}
            </section>
          );
        })
      }
    </main>
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const initSectionQuizzes = () => {
      const panels = document.querySelectorAll("[data-section-quiz]");
      for (const panel of panels) {
        if (!(panel instanceof HTMLElement) || panel.dataset.enhanced === "true") continue;
        panel.dataset.enhanced = "true";

        const questions = JSON.parse(panel.dataset.sectionQuiz || "[]");
        if (questions.length === 0) continue;

        const stage = panel.querySelector("[data-quiz-stage]");
        const progressBar = panel.querySelector("[data-quiz-progress]");
        let currentQ = 0;
        let score = 0;

        function updateProgress() {
          if (progressBar instanceof HTMLElement) {
            progressBar.style.width = ((currentQ / questions.length) * 100) + "%";
          }
        }

        function renderSummary() {
          if (!(stage instanceof HTMLElement)) return;
          stage.innerHTML = "";

          const title = document.createElement("div");
          title.className = "gram-quiz-summary-title";
          title.textContent = "Готово";
          stage.appendChild(title);

          const result = document.createElement("div");
          result.className = "gram-quiz-summary-result";
          result.textContent = score + " / " + questions.length + " правилни";
          stage.appendChild(result);

          const again = document.createElement("button");
          again.className = "gram-quiz-next";
          again.type = "button";
          again.textContent = "Отново";
          again.addEventListener("click", () => {
            currentQ = 0;
            score = 0;
            renderQuestion();
          });
          stage.appendChild(again);
        }

        function renderQuestion() {
          if (!(stage instanceof HTMLElement)) return;
          const q = questions[currentQ];
          stage.innerHTML = "";

          const question = document.createElement("div");
          question.className = "gram-quiz-question";
          question.textContent = q.question;
          stage.appendChild(question);

          const options = document.createElement("div");
          options.className = "gram-quiz-options";
          q.options.forEach(function(opt, i) {
            const btn = document.createElement("button");
            btn.className = "gram-quiz-opt";
            btn.type = "button";
            btn.dataset.idx = String(i);
            btn.textContent = opt;
            options.appendChild(btn);
          });
          stage.appendChild(options);

          const feedback = document.createElement("div");
          feedback.className = "gram-quiz-feedback";
          feedback.hidden = true;
          stage.appendChild(feedback);

          updateProgress();

          const opts = options.querySelectorAll(".gram-quiz-opt");
          let answered = false;

          for (const opt of opts) {
            opt.addEventListener("click", function() {
              if (!(opt instanceof HTMLElement) || !(feedback instanceof HTMLElement)) return;
              if (answered) return;
              answered = true;
              const idx = parseInt(opt.dataset.idx || "0", 10);
              const isCorrect = idx === q.correct;
              if (isCorrect) score += 1;

              for (const o of opts) {
                if (o instanceof HTMLButtonElement) {
                  o.classList.add("gram-quiz-opt--disabled");
                  o.disabled = true;
                  if (parseInt(o.dataset.idx || "0", 10) === q.correct) {
                    o.classList.add("gram-quiz-opt--correct");
                  }
                  if (parseInt(o.dataset.idx || "0", 10) === idx && !isCorrect) {
                    o.classList.add("gram-quiz-opt--wrong");
                  }
                }
              }

              feedback.hidden = false;
              feedback.className = "gram-quiz-feedback";
              feedback.textContent = (isCorrect ? "Правилно. " : "Грешка. ") + q.explanation;

              if (currentQ < questions.length - 1) {
                const nextBtn = document.createElement("button");
                nextBtn.className = "gram-quiz-next";
                nextBtn.type = "button";
                nextBtn.textContent = "Следващ въпрос →";
                nextBtn.addEventListener("click", function() {
                  currentQ += 1;
                  renderQuestion();
                });
                feedback.appendChild(nextBtn);
                nextBtn.focus();
              } else {
                const finishBtn = document.createElement("button");
                finishBtn.className = "gram-quiz-next";
                finishBtn.type = "button";
                finishBtn.textContent = "Виж резултата →";
                finishBtn.addEventListener("click", function() {
                  currentQ += 1;
                  updateProgress();
                  renderSummary();
                });
                feedback.appendChild(finishBtn);
                finishBtn.focus();
              }
            });
          }
        }

        renderQuestion();
      }
    };

    /* Highlight active TOC link on scroll
       Only scope to in-page section links (.gram-toc-row .gram-toc-link),
       NOT the "Всички теми" links which point to other pages. */
    const initTocHighlight = () => {
      const links = document.querySelectorAll(".gram-toc-row .gram-toc-link");
      const sectionEls = document.querySelectorAll(".gram-section[id]");
      if (!links.length || !sectionEls.length) return;

      const obs = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              for (const link of links) {
                if (link instanceof HTMLElement) {
                  link.classList.toggle("gram-toc-link--active", link.getAttribute("href") === "#" + id);
                }
              }
            }
          }
        },
        { threshold: 0.1, rootMargin: "-80px 0px -60% 0px" },
      );
      for (const el of sectionEls) obs.observe(el);
    };

    /* Hover-edge (desktop) + click toggle (all devices) for the TOC */
    const initTocHover = () => {
      const handle = document.getElementById("toc-handle");
      const hoverEdge = document.getElementById("toc-hover-edge");
      const toc = document.getElementById("gram-toc");
      const overlay = document.getElementById("toc-overlay");
      if (!handle || !toc || !overlay || !hoverEdge) return;
      if (handle.dataset.enhanced === "true") return;
      handle.dataset.enhanced = "true";

      const hasHover = window.matchMedia && window.matchMedia("(hover: hover)").matches;
      let closeTimer = null;
      let pinned = false;

      const open = () => {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
        toc.dataset.open = "true";
        overlay.dataset.open = "true";
        handle.dataset.open = "true";
        handle.setAttribute("aria-expanded", "true");
      };
      const close = () => {
        if (pinned) return;
        toc.dataset.open = "false";
        overlay.dataset.open = "false";
        handle.dataset.open = "false";
        handle.setAttribute("aria-expanded", "false");
      };
      const scheduleClose = () => {
        if (closeTimer) clearTimeout(closeTimer);
        closeTimer = window.setTimeout(close, 120);
      };

      /* Hover behavior — ONLY on devices that truly support hover. On touch,
         emulated mouseenter+click race conditions made the menu open & instantly
         close again, looking like "the button does nothing". */
      if (hasHover) {
        hoverEdge.addEventListener("mouseenter", open);
        handle.addEventListener("mouseenter", open);
        toc.addEventListener("mouseenter", open);

        handle.addEventListener("mouseleave", scheduleClose);
        toc.addEventListener("mouseleave", scheduleClose);
      }

      /* Click toggle works on every device */
      handle.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const isOpen = toc.dataset.open === "true";
        if (isOpen) {
          pinned = false;
          close();
        } else {
          pinned = true;
          open();
        }
      });

      overlay.addEventListener("click", () => {
        pinned = false;
        close();
      });

      // Close on TOC link click
      const links = toc.querySelectorAll(".gram-toc-link, .gram-toc-test");
      for (const link of links) {
        link.addEventListener("click", () => {
          pinned = false;
          close();
        });
      }

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && toc.dataset.open === "true") {
          pinned = false;
          close();
        }
      });
    };

    const initAll = () => {
      initSectionQuizzes();
      initTocHighlight();
      initTocHover();
    };

    initAll();
    document.addEventListener("astro:page-load", initAll);
  })();
</script>
