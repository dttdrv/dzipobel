---
import { getCollection, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

type GrammarSection = {
  title: string;
  items: string[];
};

export async function getStaticPaths() {
  const entries = await getCollection("grammar");
  return entries.map((entry: CollectionEntry<"grammar">) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"grammar"> };
const sections: GrammarSection[] = entry.data.sections;

function classifyItem(text: string): string {
  if (/^‚ēź‚ēź‚ēź/.test(text)) return "is-separator";
  if (/^(–ü—Ä–ł–ľ–Ķ—Ä[–ł–į]?:|–ü–†–ė–ú–ē–†|–Ě–į–Ņ—Ä\.)/.test(text)) return "is-example";
  if (/^(–í–ź–Ė–Ě–ě|–ü–†–ź–í–ė–õ–ě|–ó–ź–ü–ě–ú–Ě–ė|–ü—Ä–į–≤–ł–Ľ–ĺ|–í–Ĺ–ł–ľ–į–Ĺ–ł–Ķ|–Ę—É–ļ –Ķ –≤–į–∂–Ĺ–ĺ|–ó–į–Ī–Ķ–Ľ–Ķ–∂–Ķ—ā–Ķ):/i.test(text)) return "is-rule";
  return "";
}

function isSeparatorSection(title: string): boolean {
  return /^‚ēź‚ēź‚ēź/.test(title);
}

const visibleSections = sections.filter((s) => !isSeparatorSection(s.title));
---

<BaseLayout
  title={`${entry.data.title} ‚ÄĘ –Ē–ó–ė –Ī–ł–Ī–Ľ–ł–ĺ—ā–Ķ–ļ–į`}
  description={entry.data.excerpt}
  hideNav={true}
>
  <section class="detail-header">
    <a href="/" class="back-link" aria-label="–ě–Ī—Ä–į—ā–Ĺ–ĺ">‚Üź</a>
    <span class="detail-kicker">{entry.data.module}</span>
    <h1 class="detail-title" transition:name={`title-${entry.id}`}>{entry.data.title}</h1>
    <p class="detail-meta">{visibleSections.length} —Ä–į–∑–ī–Ķ–Ľ–į</p>
  </section>

  <div class="detail-content">
    <div class="acc-toolbar">
      <button class="acc-toggle-all" data-expand-all>–ě—ā–≤–ĺ—Ä–ł –≤—Ā–ł—á–ļ–ł</button>
    </div>

    {
      sections.map((section) => {
        const isSep = isSeparatorSection(section.title);

        if (isSep) {
          return (
            <div class="acc-divider" role="separator">
              <span>{section.title.replace(/‚ēź/g, "").trim()}</span>
            </div>
          );
        }

        return (
          <details class="acc" data-accordion name="grammar-sections">
            <summary class="acc-head">
              <span class="acc-title">{section.title}</span>
              <span class="acc-chevron" aria-hidden="true"></span>
            </summary>
            <div class="acc-body">
              <ul>
                {section.items.map((item: string) => {
                  const cls = classifyItem(item);
                  return <li class={cls || undefined}>{item}</li>;
                })}
              </ul>
            </div>
          </details>
        );
      })
    }
  </div>
</BaseLayout>

<script is:inline>
  (() => {
    const initAccordion = () => {
      const toggleBtn = document.querySelector("[data-expand-all]");
      if (!(toggleBtn instanceof HTMLElement) || toggleBtn.dataset.enhanced === "true") return;
      toggleBtn.dataset.enhanced = "true";

      const allDetails = Array.from(document.querySelectorAll("[data-accordion]"));
      let allOpen = false;

      toggleBtn.addEventListener("click", () => {
        allOpen = !allOpen;
        for (const d of allDetails) {
          if (d instanceof HTMLDetailsElement) {
            d.open = allOpen;
          }
        }
        toggleBtn.textContent = allOpen ? "–ó–į—ā–≤–ĺ—Ä–ł –≤—Ā–ł—á–ļ–ł" : "–ě—ā–≤–ĺ—Ä–ł –≤—Ā–ł—á–ļ–ł";
      });
    };

    initAccordion();
    document.addEventListener("astro:page-load", initAccordion);
  })();
</script>
